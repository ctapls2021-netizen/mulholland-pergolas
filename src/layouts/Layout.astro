---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<!-- Google Tag Manager -->
		<script is:inline>
			(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
			new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
			j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
			'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
			})(window,document,'script','dataLayer','GTM-MSS2VZ5');
		</script>
		<!-- End Google Tag Manager -->
		<meta charset="UTF-8" />
		<meta name="description" content="Mulholland Brand - Custom Aluminum Gates & Fences" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/assets/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<!-- AOS CSS -->
		<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
	</head>
	<body>
		<!-- Google Tag Manager (noscript) -->
		<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MSS2VZ5"
		height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		<!-- End Google Tag Manager (noscript) -->
		<slot />

		<!-- Global Mobile Bottom Call Bar -->
		<div class="mobile-sticky-cta">
			<a href="tel:8005625770" class="m-sticky-btn">
				<img src="/assets/images/icon_phone.svg" alt="Phone" class="m-sticky-icon" />
				<span>Call Now: (800) 562-5770</span>
			</a>
		</div>

		<!-- Webhook Form Submission Handler -->
		<script is:inline>
			document.addEventListener('DOMContentLoaded', () => {
				const forms = document.querySelectorAll('.hero-form, .cta-form');
				forms.forEach(form => {
					form.addEventListener('submit', async (event) => {
						event.preventDefault();
						
						const btn = form.querySelector('button[type="submit"]');
						const originalText = btn.innerHTML;
						
						// Disable form button to prevent double-submit
						btn.disabled = true;
						btn.innerHTML = "Sending...";

						// Extract fields
						const formData = new FormData(form);
						const data = {};
						formData.forEach((value, key) => {
							data[key] = value;
						});

						// Add page details & tracking parameter payload
						data['url'] = window.location.href;
						data['title'] = document.title;
						data['formType'] = form.classList.contains('hero-form') ? 'Hero Form' : 'Footer CTA Form';

						try {
							await fetch('https://hooks.zapier.com/hooks/catch/441644/42fuufs/', {
								method: 'POST',
								body: JSON.stringify(data)
							});

							btn.innerHTML = "Thank You!";
							btn.style.backgroundColor = "#28a745";
							btn.style.color = "#ffffff";
							form.reset();
						} catch (err) {
							console.error(err);
							btn.disabled = false;
							btn.innerHTML = originalText;
							alert("There was an error sending your message. Please try again or call us.");
						}
					});
				});
			});
		</script>
		<!-- AOS JS -->
		<script is:inline src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
		<script is:inline>
			document.addEventListener('DOMContentLoaded', function() {
				AOS.init({
					duration: 800,
					once: true,
					offset: 100,
					disable: 'mobile' // Disable on very small devices if it causes issues, but we'll try keeping it by default. Actually let's just initialize it for all.
				});
				AOS.init({
					duration: 800,
					once: true,
					offset: 50
				});
			});
		</script>
	</body>
</html>

<style>
  .mobile-sticky-cta {
    display: none;
  }
  @media (max-width: 768px) {
    .mobile-sticky-cta {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 44px;
      background-color: rgba(44, 101, 176, 0.90);
      align-items: center;
      justify-content: center;
      z-index: 2147483647 !important; /* Maximum possible z-index */
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
    }
    .m-sticky-btn {
      width: 280px;
      height: 30px;
      border-radius: 26px;
      background-color: rgba(255, 255, 255, 0.11);
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      gap: 5px;
    }
    .m-sticky-btn span {
      font-family: 'Inter', sans-serif;
      font-weight: 700;
      font-size: 12px;
      line-height: 15.5px;
      color: #EAC848 !important;
    }
    .m-sticky-icon {
      width: 14px !important;
      height: auto !important;
      object-fit: contain;
      filter: brightness(0) saturate(100%) invert(84%) sepia(24%) saturate(1402%) hue-rotate(345deg) brightness(99%) contrast(96%) !important;
    }
  }
</style>

<style is:global>
  @media (max-width: 768px) {
    body {
      padding-bottom: 44px;
    }
  }
</style>
