---
---
<section class="gallery-one">
  <!-- DESKTOP GALLERY -->
  <div class="g1-desktop desktop-only">
    <div class="g1-top desktop-only">
      <img src="/assets/images/gallery-1/Mulholland brand (1).webp" alt="Main Gate" class="g1-main-img" />
      <div class="g1-diagram-wrapper">
        <img src="/assets/images/gallery-1/icon line.svg" alt="Line pointing to gate" class="g1-line-icon" />
        <img src="/assets/images/gallery-1/Mulholland brand (5).webp" alt="IST Diagram" class="g1-diagram-img" />
      </div>
    </div>
    <div class="g1-bottom desktop-only">
      <img src="/assets/images/gallery-1/Mulholland brand (3).webp" alt="Gallery Gate 3" />
      <img src="/assets/images/gallery-1/Mulholland brand (4).webp" alt="Gallery Gate 4" />
      <img src="/assets/images/gallery-1/Mulholland brand (2).webp" alt="Gallery Gate 5" />
    </div>
  </div>

  <!-- MOBILE GALLERY -->
  <div class="g1-mobile">
    <div class="g1-mobile-images">
      <img src="/assets/images/gallery-1/movil/Mulholland-brand (1).jpg" alt="Gallery Gate Mobile 1" class="g1-m-main" />
      <div class="g1-m-split">
        <img src="/assets/images/gallery-1/movil/Mulholland-brand (3).jpg" alt="Gallery Gate Mobile 3" />
        <img src="/assets/images/gallery-1/movil/Mulholland-brand (2).jpg" alt="Gallery Gate Mobile 2" />
      </div>
    </div>
  </div>
</section>

<style>
  .gallery-one {
  width: 100%;
  display: flex;
  flex-direction: column;
  background: #ffffff;
  padding-top: 0;
  }

  .g1-desktop {
  display: flex;
  flex-direction: column;
  gap: 11px;
  }

  .g1-mobile {
  display: none;
  }

 /* ─── TOP SECTION ───────────────────────────────────────── */
 .g1-top {
 position: relative;
 width: 100%;
 display: flex;
 }

 .g1-main-img {
 width: 100%;
 aspect-ratio: 1920 / 722;
 object-fit: cover;
 display: block;
 }

 .g1-diagram-wrapper {
 position: absolute;
 top: 50%;
 right: 5%;
 transform: translateY(-50%);
 display: flex;
 align-items: center;
 z-index: 5;
 }

 .g1-line-icon {
 width: 163px; /* Actual SVG width */
 max-width: 15vw; /* Scale on mobile */
 height: auto;
 /* Pull diagram closer so line overlaps/connects visually */
 margin-right: -1vw; 
 z-index: 2;
 }

 .g1-diagram-img {
 width: 748px; 
 aspect-ratio: 748 / 439; /* Keep proportions */
 height: auto;
 max-width: 45vw;
 object-fit: contain;
 background: transparent; /* Changed from white to transparent to prevent extra edges */
 border: none; /* Image already has a border */
 display: block;
 position: relative;
 z-index: 1;
 box-shadow: 0 10px 30px rgba(0,0,0,0.3);
 }

 /* ─── BOTTOM SECTION ────────────────────────────────────── */
 .g1-bottom {
 display: grid;
 grid-template-columns: repeat(3, 1fr);
 gap: 11px 16px; /* Row gap 11px, Column gap 16px */
 width: 100%;
 }

 .g1-bottom img {
 width: 100%;
 aspect-ratio: 629 / 351; 
 object-fit: cover;
 display: block;
 }

 /* ─── RESPONSIVE ────────────────────────────────────────── */
  @media (max-width: 768px) {
  .g1-desktop, .g1-top, .g1-bottom, .desktop-only {
  display: none !important;
  }
  .g1-mobile {
  display: flex;
  flex-direction: column;
  padding-top: 30px;
  }
  .g1-mobile-images {
  display: flex;
  flex-direction: column;
  }
  .g1-m-main {
  width: 100%;
  height: auto;
  display: block;
  }
  .g1-m-split {
  display: flex;
  width: 100%;
  }
  .g1-m-split img {
  width: 50%;
  height: auto;
  display: block;
  }
  .g1-mobile-cta {
  background: #2C65B0;
  padding: 16px 10px;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
  text-decoration: none;
  width: 100%;
  box-sizing: border-box;
  }
  .g1-m-cta-text {
  font-family: 'Raleway', sans-serif;
  font-size: clamp(10px, 3vw, 14px);
  color: #ffffff;
  font-weight: 500;
  }
  .g1-m-cta-phone {
  font-family: 'Raleway', sans-serif;
  font-size: clamp(10px, 3vw, 14px);
  color: #EAC848;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 5px;
  }
  .g1-m-phone-icon {
  width: 12px;
  height: auto;
  }
  }

  @media (max-width: 768px) {
  .g1-main-img,
  .g1-bottom img {
  aspect-ratio: 629 / 351;
  height: auto;
  }
  }
</style>
