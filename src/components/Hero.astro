---
// TRIGGER HMR UPDATE
---
<section class="hero">
 <div class="hero-inner">

  <!-- LEFT COLUMN -->
  <div class="hero-left">
  <div class="hero-left-content">
  <!-- Pill badge -->
  <div class="hero-pill">
  <span class="hero-pill-dot"></span>
  Luxury Gates &amp; Fences
  </div>

  <!-- H1 -->
  <h1 class="hero-title">
  Elevate Your Curb Appeal.<br />Upgrade Your Security.
  </h1>

  <!-- Promo Box -->
  <div class="hero-promo-box">
    <p class="hero-promo-line1">
      <span class="hero-promo-gold">Up to 30% OFF</span>
      <span class="hero-promo-white"> Select Glass Products</span>
    </p>
    <p class="hero-promo-sub">Available in Black, White &amp; Clear Glass</p>
  </div>

  <!-- Product list -->
  <p class="hero-products">Custom Gates &bull; Fences &bull; Railings &bull; Glass Systems</p>
  <p class="hero-supply">Limited Supply Available</p>

  <!-- Two CTA Buttons -->
  <div class="hero-buttons">
  <a href="#estimate" class="hero-btn hero-btn-primary">Request Free On-Site Estimate</a>
  <a href="tel:+18005625770" class="hero-btn hero-btn-secondary">
  <img src="/assets/images/icon_phone.svg" alt="" class="btn-phone-icon" />
  Or Call Now: (800) 562-5770
  </a>
  </div>
  </div><!-- /hero-left-content -->

  <!-- Bottom icons + 30+ stat all inline in same row -->
  <div class="hero-trust-icons">
  <div class="trust-item">
  <img src="/assets/images/icon_30years.svg" alt="30+ Years Experience" />
  <span>30+ Years Experience</span>
  </div>
  <div class="trust-item">
  <img src="/assets/images/icon_lafactory.svg" alt="Made in Our LA Factory" />
  <span>Made in Our LA Factory</span>
  </div>
  <div class="trust-item">
  <img src="/assets/images/icon_aluminum.svg" alt="Rust-Proof Aluminum" />
  <span>Rust-Proof Aluminum</span>
  </div>
  <div class="trust-item">
  <img src="/assets/images/icon_financing.svg" alt="0% Financing Available" />
  <span>0% Financing Available</span>
  </div>

  <!-- 30+ stat: inline after icons, with horizontal separator -->
  <div class="hero-stat">
  <p class="hero-stat-number">30<sup>+</sup></p>
  <div class="hero-stat-line"></div>
  <p class="hero-stat-text">
    <span class="hstat-line1">Years Designing, Manufacturing &amp; Installing</span>
    <span class="hstat-line2">Across Southern California</span>
  </p>
  </div>
  </div>



  </div><!-- /hero-left -->

 <!-- FINANCING BAR — solo mobile, entre hero y form -->
 <div class="financing-bar financing-bar--mobile">
   <div class="financing-inner">
     <p class="financing-text">
       <span class="financing-text-lines">
         <span class="financing-line-rule"></span>
         <span class="financing-label">
           <span class="financing-gold">0% FINANCING</span>
           <span class="financing-white"> AVAILABLE</span>
         </span>
         <span class="financing-line-rule"></span>
       </span>
     </p>
     <div class="financing-cards">
       <img src="/assets/images/hero/movil/cc-paypal 1.svg" alt="PayPal" class="financing-card-icon" />
       <img src="/assets/images/hero/movil/cc-amex 1.svg" alt="Amex" class="financing-card-icon" />
       <img src="/assets/images/hero/movil/cc-discover 1.svg" alt="Discover" class="financing-card-icon" />
       <img src="/assets/images/hero/movil/cc-mastercard 1.svg" alt="Mastercard" class="financing-card-icon" />
       <img src="/assets/images/hero/movil/cc-visa 1.svg" alt="Visa" class="financing-card-icon" />
     </div>
   </div>
 </div>

 <!-- RIGHT COLUMN: Form -->
 <div class="hero-form-col" id="estimate">
 <div class="hero-form-card">
 <h2 class="form-title">Ready To Get Started<br />On Your Project?</h2>
 <form class="hero-form">
 <input type="text" name="name" placeholder="Name" required />
 <input type="email" name="email" placeholder="Email" required />
 <input type="tel" name="phone" placeholder="Phone" required />
 <input type="text" name="zip" placeholder="Zip Code" required />
 <div class="select-wrap">
 <select name="interest" required>
 <option value="" disabled selected>Product Interest</option>
 <option value="gate">Custom Gate</option>
 <option value="fence">Custom Fence</option>
 <option value="both">Both</option>
 </select>
 <span class="select-arrow">&#x2304;</span>
 </div>
 <button type="submit" class="form-btn">SCHELUDE YOUR FREE CONSULTATION</button>
 </form>
 </div>
 </div><!-- /hero-form-col -->

 </div><!-- /hero-inner -->


</section>

<!-- ─── FINANCING BAR (desktop) ──────────────────────────────────── -->
<div class="financing-bar financing-bar--desktop">
  <div class="financing-inner">
    <p class="financing-text">
      <span class="financing-text-lines">
        <span class="financing-line-rule"></span>
        <span class="financing-label">
          <span class="financing-gold">0% FINANCING</span>
          <span class="financing-white"> AVAILABLE</span>
        </span>
        <span class="financing-line-rule"></span>
      </span>
    </p>
    <div class="financing-cards">
      <img src="/assets/images/hero/cc-paypal 1.svg" alt="PayPal" class="financing-card-icon" />
      <img src="/assets/images/hero/cc-amex 1.svg" alt="Amex" class="financing-card-icon" />
      <img src="/assets/images/hero/cc-discover 1.svg" alt="Discover" class="financing-card-icon" />
      <img src="/assets/images/hero/cc-mastercard 1.svg" alt="Mastercard" class="financing-card-icon" />
      <img src="/assets/images/hero/cc-visa 1.svg" alt="Visa" class="financing-card-icon" />
    </div>
    <p class="financing-link">
      <img src="/assets/images/hero/Arrow 4.svg" alt="" class="financing-arrow" />
      Flexible Payment Options for Your Project
    </p>
  </div>
</div>

<style>
 /* ─── Google Fonts ──────────────────────────────────────── */
 @import url('https://fonts.googleapis.com/css2?family=Raleway:wght@400;700;800&family=Inter:wght@400;600;700;800&family=Poppins:wght@600;700&family=Playfair+Display:wght@500&display=swap');

 /* ─── Section ───────────────────────────────────────────── */
 .hero {
 position: relative;
 width: 100%;
 height: 100vh;
 min-height: 700px;
 background-image: url('/assets/images/hero_bg.jpg');
 background-size: cover;
 background-position: center top;
 background-repeat: no-repeat;
 display: flex;
 align-items: stretch;
 overflow: hidden;
 /* No overlay — the image already has its own darkness */
 }

 /* ─── Inner layout ─────────────────────────────────────── */
 .hero-inner {
 position: relative;
 z-index: 1;
 width: 100%;
 max-width: 1920px;
 margin: 0 auto;
 padding-left: 110px;
 padding-right: 40px; /* form aligns with header */
 display: flex;
 align-items: stretch;
 justify-content: space-between;
 }

 /* ─── LEFT ─────────────────────────────────────────────── */
 .hero-left {
 display: flex;
 flex-direction: column;
 justify-content: center;
 flex: 1;
 padding-right: 40px;
 padding-top: 80px; /* push below fixed header */
 padding-bottom: 40px;
 min-width: 0; /* allow flex shrink */
 }

 /* Pill */
 .hero-pill {
 display: inline-flex;
 align-items: center;
 gap: 8px;
 background: rgba(0, 0, 0, 0.36);
 border: 1px solid #E5E2DE;
 border-radius: 30px;
 height: 30px;
 padding: 0 14px;
 font-family: 'Inter', sans-serif;
 font-weight: 500;
 font-size: 12px;
 line-height: 16px;
 letter-spacing: 2.1px;
 text-transform: uppercase;
 color: #CCC6C0;
 width: fit-content;
 margin-bottom: 28px;
 }
 .hero-pill-dot {
 width: 6px;
 height: 6px;
 background: #EAC848;
 border-radius: 50%;
 flex-shrink: 0;
 }

 /* H1 */
 .hero-title {
 font-family: 'Raleway', sans-serif;
 font-weight: 700;
 font-size: clamp(40px, 4vw, 60px); /* Fluid typography */
 line-height: 1.05;
 letter-spacing: -1.5px;
 color: #ffffff;
 margin: 0 0 24px 0;
 max-width: 900px;
 }

 /* Promo Box */
 .hero-promo-box {
 display: inline-flex;
 flex-direction: column;
 align-items: center;
 border: 1px solid #D9D9D9;
 width: 613px;
 max-width: 100%;
 min-height: 90px;
 padding: 12px 20px;
 margin: 0 0 16px 0;
 justify-content: center;
 box-sizing: border-box;
 }
 .hero-promo-line1 {
 font-family: 'Raleway', sans-serif;
 font-size: 32px;
 line-height: 29px;
 margin: 0 0 6px 0;
 text-align: center;
 }
 .hero-promo-gold {
 font-weight: 800;
 color: #EAC848;
 }
 .hero-promo-white {
 font-weight: 400;
 color: #ffffff;
 }
 .hero-promo-sub {
 font-family: 'Inter', sans-serif;
 font-weight: 400;
 font-style: italic;
 font-size: 15px;
 line-height: 20px;
 color: #ffffff;
 margin: 0;
 opacity: 0.85;
 text-align: center;
 }

 /* Product list & supply */
 .hero-products {
 font-family: 'Inter', sans-serif;
 font-weight: 700;
 font-size: 18px;
 line-height: 24px;
 color: #ffffff;
 margin: 0 0 4px 0;
 width: 613px;
 max-width: 100%;
 text-align: center;
 }
 .hero-supply {
 font-family: 'Inter', sans-serif;
 font-weight: 500;
 font-style: italic;
 font-size: 14px;
 line-height: 29px;
 color: #ffffff;
 margin: 0 0 28px 0;
 width: 613px;
 max-width: 100%;
 text-align: center;
 }


 /* ─── Buttons ───────────────────────────────────────────── */
 .hero-buttons {
 display: flex;
 flex-wrap: wrap;
 gap: 12px;
 width: 100%;
 max-width: 582px;
 min-height: 50px;
 margin-bottom: 48px;
 }

 .hero-btn {
 flex: 1;
 display: flex;
 align-items: center;
 justify-content: center;
 text-decoration: none;
 font-family: 'Inter', sans-serif;
 font-weight: 600;
 font-size: 14px;
 line-height: 20px;
 color: #FCFCFC;
 border-radius: 3px;
 transition: opacity 0.25s;
 white-space: nowrap;
 gap: 8px;
 }
 .hero-btn:hover { opacity: 0.88; }

 .hero-btn-primary { background: #2C65B0; }
 .hero-btn-secondary {
 background: rgba(1, 1, 1, 0.23);
 border: 1px solid #D7B174;
 }

 .btn-phone-icon {
 height: 18px;
 width: auto;
 object-fit: contain;
 }

 /* ─── Icons + 30+ stat — all in one flex row ─────────────── */
 .hero-trust-icons {
 display: flex;
 flex-wrap: nowrap;
 align-items: flex-end;
 gap: clamp(10px, 1.5vw, 24px);
 }

 .trust-item {
 display: flex;
 flex-direction: column;
 align-items: flex-start;
 gap: 6px;
 flex-shrink: 0; /* never shrink the icon items */
 }
 .trust-item img {
 height: 26px; /* smaller icons */
 width: auto;
 object-fit: contain;
 image-rendering: -webkit-optimize-contrast; /* Try to make it sharper */
 image-rendering: crisp-edges;
 }
 .trust-item span {
 font-family: 'Inter', sans-serif;
 font-weight: 600;
 font-size: 12px;
 line-height: 18px;
 color: #ffffff;
 text-align: left;
 white-space: nowrap; /* never break the label onto 2 lines */
 }

 /* 30+ stat — inline sibling of .trust-item */
 .hero-stat {
 display: flex;
 flex-direction: column;
 align-items: center; /* center horizontally */
 margin-left: clamp(10px, 2vw, 24px);
 }
 .hero-stat-number {
 font-family: 'Playfair Display', serif;
 font-weight: 500;
 font-size: 64px;
 line-height: 36px;
 color: #EAC848;
 margin: 0;
 }
 .hero-stat-number sup {
 font-size: 36px;
 vertical-align: super;
 line-height: 0;
 }
 .hero-stat-line {
 width: 260px; /* Reduced from 308px for better fit */
 height: 1px;
 background: #EAC848;
 margin: 20px 0 12px 0; /* Reduced margin */
 }
  .hero-stat-text {
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  font-size: 14px;
  line-height: 19px;
  color: #ffffff;
  margin: 0;
  text-align: center;
  }
  .hstat-line1,
  .hstat-line2 {
  display: block !important;
  white-space: nowrap !important;
  }

 /* ─── RIGHT: Form column ─────────────────────────────────── */
  .hero-form-col {
  width: 100%;
  max-width: 577px;
  min-width: 350px; /* Let it shrink on 1280px */
  flex: 0 1 577px;
  height: 100vh; /* match section height */
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 0;
  }
 
  .hero-form-card {
  width: 100%;
  max-width: 577px;
  height: auto;
  min-height: 589px;
  background: linear-gradient(to bottom, #5E97D5 0%, #4467AB 100%);
  padding: clamp(24px, 3vw, 44px) clamp(24px, 3vw, 48px);
  display: flex;
  flex-direction: column;
  justify-content: center;
  box-shadow: -8px 0 40px rgba(0,0,0,0.25);
  box-sizing: border-box;
  }
 
  .form-title {
  font-family: 'Raleway', sans-serif;
  font-weight: 800;
  font-size: 36px;
  line-height: 37px;
  color: #ffffff;
  text-align: center;
  margin: 0 0 28px 0;
  }

 .hero-form {
 display: flex;
 flex-direction: column;
 gap: 12px;
 }

 .hero-form input,
 .hero-form select {
 width: 100%;
 height: 48px;
 padding: 0 16px;
 border: 1px solid #C3C3C3;
 background: #ffffff;
 font-family: 'Poppins', sans-serif;
 font-weight: 600;
 font-size: 15px;
 line-height: 18px;
 color: #182C49;
 box-sizing: border-box;
 outline: none;
 }
 .hero-form input::placeholder { color: #182C49; }

 .select-wrap {
 position: relative;
 }
 .select-wrap select {
 appearance: none;
 -webkit-appearance: none;
 cursor: pointer;
 }
 .select-arrow {
 position: absolute;
 right: 16px;
 top: 50%;
 transform: translateY(-50%);
 font-size: 18px;
 color: #182C49;
 pointer-events: none;
 }

 .form-btn {
 width: 100%;
 height: 50px;
 background: #EAC848;
 border: none;
 font-family: 'Poppins', sans-serif;
 font-weight: 700;
 font-size: 18px;
 line-height: 12px;
 color: #182C49;
 cursor: pointer;
 letter-spacing: 0.5px;
 transition: background 0.25s;
 margin-top: 4px;
 }
 .form-btn:hover { background: #d4b03a; }

 /* ─── Responsive ────────────────────────────────────────── */
    @media (max-width: 1600px) {
    .hero-inner { padding-left: 60px; }
    .hero-title { font-size: 48px; }
    .hero-form-col {
      max-width: 440px;
      flex: 0 1 440px;
      min-width: 320px;
      margin-left: 20px;
    }
    .hero-form-card {
      max-width: 440px;
      padding: 36px 30px;
    }
    .form-title {
      font-size: 30px;
      line-height: 34px;
      margin: 0 0 24px 0;
    }
    }

   @media (max-width: 1440px) {
     .hero-inner {
       padding-left: 30px;
       padding-right: 30px;
     }
     .hero-left {
       padding-right: 15px !important;
    }
    .hero-form-col {
      max-width: 410px !important;
      flex: 0 1 410px !important;
      margin-left: 10px !important;
    }
    .hero-form-card {
      max-width: 410px !important;
      padding: 30px 24px !important;
    }
    .form-title {
      font-size: 28px !important;
      line-height: 32px !important;
    }
    .hero-trust-icons {
      gap: 8px !important;
    }
    .trust-item span {
      font-size: 11px !important;
    }
    .hero-stat {
      margin-left: 8px !important;
    }
    .hero-stat-line {
      width: 210px !important;
    }
    .hero-stat-text {
      font-size: clamp(8px, 0.75vw, 11px) !important;
      line-height: 1.3 !important;
    }
  }

   @media (max-width: 1400px) {
   .hero-title { font-size: 42px; }
   }

 @media (max-width: 1200px) {
  .hero {
  height: auto;
  min-height: 100svh;
  }
  .hero-inner {
  flex-direction: column;
  padding: 120px 24px 60px;
  align-items: center;
  text-align: center;
  }
  .hero-left {
  padding-right: 0;
  max-width: 100%;
  padding-top: 0;
  align-items: center;
  }
  .hero-title, .hero-desc-regular, .hero-desc-bold {
  margin-left: auto;
  margin-right: auto;
  text-align: center;
  }
  .hero-buttons {
  width: 100%;
  justify-content: center;
  }
  .hero-trust-icons {
  justify-content: center;
  margin-bottom: 40px;
  }
  .hero-stat {
  margin-left: 0;
  margin-top: 20px;
  }
  .hero-form-col {
  width: 100%;
  min-width: unset;
  height: auto;
  justify-content: center;
  }
  .hero-form-card {
  width: 100%;
  max-width: 600px;
  height: auto;
  margin: 0 auto;
  }
  }

  @media (max-width: 768px) {
  .hero {
  background-image: none;
  min-height: auto;
  height: auto;
  }
  .hero-inner {
  padding: 0;
  gap: 0;
  }
  .hero-left {
  flex: none;
  height: calc(100vh - 52px);
  height: calc(100svh - 52px);
  width: 100%;
  background-image: 
    linear-gradient(to bottom, rgba(0,0,0,0) 30%, rgba(0,0,0,0.7) 65%, #050505 95%),
    url('/assets/images/hero/movil/-Mulholland-.webp');
  background-size: cover;
  background-position: center top;
  background-color: transparent;
  padding: 0; /* Reset desktop paddings */
  margin: 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  }
  .hero-left-content {
  flex: 1;
  padding: 70px 20px 0 20px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
  }
  .hero-pill {
  display: none;
  }
  .hero-title {
  font-size: 24px !important;
  line-height: 1.2 !important;
  letter-spacing: -0.65px !important;
  text-align: center;
  margin-bottom: 20px;
  max-width: 100%;
  }
  .hero-desc-regular, .hero-desc-bold, .hero-btn-secondary, .hero-stat {
  display: none !important;
  }
  .hero-buttons {
  width: 100%;
  margin: 0 0 28px 0; /* Exact 28px gap to trust icons */
  display: flex;
  justify-content: center;
  }
  .hero-btn-primary {
  flex: none;
  width: 212px;
  height: 39px;
  min-height: 39px;
  font-size: 11px;
  line-height: 16px;
  margin: 0;
  }
  .hero-trust-icons {
  background: transparent;
  width: 100%;
  margin: 0;
  padding: 0 10px 60px 10px;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  box-sizing: border-box;
  flex-wrap: nowrap;
  gap: 5px;
  }
  .trust-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  }
  .trust-item img {
  height: 28px;
  width: auto;
  margin: 0;
  }
  .trust-item span {
  font-size: 10px;
  line-height: 1.2;
  text-align: center;
  white-space: normal;
  }
  .hero-form-col {
  flex: none;
  padding: 0;
  margin: 0 !important;
  height: auto;
  width: 100% !important;
  max-width: 100% !important;
  }
  .hero-form-card {
  width: 100% !important;
  max-width: 100% !important;
  height: auto;
  min-height: unset;
  border-radius: 0;
  padding: 30px 32px 50px 32px; /* 30px top, 32px sides, 50px bottom */
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  margin: 0;
  }
  .form-title {
  font-size: 24px;
  line-height: 1.2;
  margin-bottom: 28px; /* Calculated to match 461px total height */
  }
  .hero-form {
  display: flex;
  flex-direction: column;
  gap: 14px !important; /* Calculated */
  }
  .hero-form input,
  .hero-form select,
  .hero-form input::placeholder {
  font-size: 15px !important;
  line-height: 18px !important;
  }
  .hero-form input,
  .hero-form select {
  height: 50px !important; /* Calculated */
  }
  .form-btn {
  font-size: 14px !important;
  line-height: 12px !important;
  height: 55px !important; /* Calculated */
  margin-top: 0 !important;
  }

  /* ── Promo mobile: líneas blancas en vez de recuadro ── */
  .hero-promo-box {
  width: calc(100% + 40px) !important;
  max-width: calc(100% + 40px) !important;
  border: none !important;
  border-top: 1px solid #ffffff !important;
  border-bottom: 1px solid #ffffff !important;
  padding: 10px 20px !important;
  margin: 0 -20px 8px -20px !important;
  align-items: center !important;
  }

  /* "Up to 30% OFF" en su propia línea */
  .hero-promo-gold {
  display: block;
  font-size: 24px !important;
  line-height: 25px !important;
  text-align: center;
  }

  /* "Select Glass Products" en su propia línea con tamaño distinto */
  .hero-promo-white {
  display: block;
  font-size: 18px !important;
  line-height: 25px !important;
  text-align: center;
  }

  .hero-promo-line1 {
  font-size: unset !important;
  line-height: unset !important;
  margin: 0 !important;
  text-align: center;
  }

  .hero-promo-sub {
  font-size: 14px !important;
  line-height: 29px !important;
  }

  .hero-products {
  font-size: 11px !important;
  line-height: 29px !important;
  width: 100% !important;
  }

  .hero-supply {
  font-size: 11px !important;
  line-height: 29px !important;
  width: 100% !important;
  margin-bottom: 16px !important;
  }

  /* ── Financing bar mobile ── */
  .financing-bar {
  height: 128px !important;
  padding: 0 20px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  }

  .financing-inner {
  flex-direction: column !important;
  align-items: center !important;
  justify-content: center !important;
  gap: 8px !important;
  padding: 0 !important;
  width: fit-content !important;
  height: 100% !important;
  }

  .financing-text {
  width: 100% !important;
  }

