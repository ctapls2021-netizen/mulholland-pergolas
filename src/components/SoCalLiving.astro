---
// SoCalLiving.astro
---
<section class="socal-section">
  
  <!-- DESKTOP VERSION -->
  <div class="scl-desktop">
    <div class="socal-header">
      <div class="socal-subtitle">
        <img src="/assets/images/pergolas/socal/icon-arrow.svg" alt="Arrow" class="socal-arrow" />
        <span class="socal-blue-italic">SO-CAL</span>
        <span class="socal-dark-italic">LIVING</span>
      </div>
      <h2 class="socal-title">
        Inspirational transformations across <span class="socal-blue-title">Southern California</span>
      </h2>
      <p class="socal-desc">
        Explore real-world projects designed, manufactured, and installed by our team. See how we combine shade, privacy, and premium architectural style.
      </p>
    </div>

    <div class="socal-grid">
      <!-- Bel Air -->
      <div class="socal-item item-belair">
        <img src="/assets/images/pergolas/socal/bel-air.jpg" alt="Bel Air Pergola" class="socal-img" />
        <div class="socal-overlay">
          <span class="socal-city">BEL AIR, CA</span>
          <span class="socal-project">Motorized Louvered Pergola with Free Leaf-Pattern Privacy Screen</span>
        </div>
      </div>
      <!-- Pasadena -->
      <div class="socal-item item-pasadena">
        <img src="/assets/images/pergolas/socal/pasadena.jpg" alt="Pasadena Pergola" class="socal-img" />
        <div class="socal-overlay">
          <span class="socal-city">PASADENA, CA</span>
          <span class="socal-project">Motorized Louvered Pergola with Free Leaf-Pattern Privacy Screen</span>
        </div>
      </div>
      <!-- Sherman Oaks -->
      <div class="socal-item item-sherman">
        <img src="/assets/images/pergolas/socal/sherman-oaks.jpg" alt="Sherman Oaks Pergola" class="socal-img" />
        <div class="socal-overlay">
          <span class="socal-city">SHERMAN OAKS, CA</span>
          <span class="socal-project">Aluminum Pergola with Integrated Side Privacy Slats</span>
        </div>
      </div>
      <!-- Del Mar -->
      <div class="socal-item item-delmar">
        <img src="/assets/images/pergolas/socal/del-mar.jpg" alt="Del Mar Pergola" class="socal-img" />
        <div class="socal-overlay">
          <span class="socal-city">DEL MAR, CA</span>
          <span class="socal-project">Modern Attached Louvered Pergola with Integrated LED Lighting</span>
        </div>
      </div>
    </div>
  </div>

  <!-- MOBILE VERSION -->
  <div class="scl-mobile">
    <div class="scl-m-header">
      <div class="scl-m-badge">
        <span class="scl-m-socal">SO-CAL</span>
        <span class="scl-m-living">LIVING</span>
      </div>
      <h2 class="scl-m-title">
        Inspirational transformations<br/>across <span class="scl-m-blue-title">Southern California</span>
      </h2>
    </div>

    <div class="scl-m-slider">
      <div class="scl-m-track">
        
        <!-- ORIGINAL SET -->
        <div class="scl-m-item">
          <img src="/assets/images/socal/mobile/Bel_Air_CA.jpg" alt="Bel Air, CA" class="scl-m-img" />
          <div class="scl-m-overlay">
            <span class="scl-m-city">BEL AIR, CA</span>
            <span class="scl-m-project">Motorized Louvered Pergola with Free Leaf-Pattern Privacy Screen</span>
          </div>
        </div>
        <div class="scl-m-item">
          <img src="/assets/images/socal/mobile/Pasadena_CA.jpg" alt="Pasadena, CA" class="scl-m-img" />
          <div class="scl-m-overlay">
            <span class="scl-m-city">PASADENA, CA</span>
            <span class="scl-m-project">Motorized Louvered Pergola with Free Leaf-Pattern Privacy Screen</span>
          </div>
        </div>
        <div class="scl-m-item">
          <img src="/assets/images/socal/mobile/Sherman_Oaks_CA.jpg" alt="Sherman Oaks, CA" class="scl-m-img" />
          <div class="scl-m-overlay">
            <span class="scl-m-city">SHERMAN OAKS, CA</span>
            <span class="scl-m-project">Aluminum Pergola with Integrated Side Privacy Slats</span>
          </div>
        </div>
        <div class="scl-m-item">
          <img src="/assets/images/socal/mobile/Del_Mar_CA.jpg" alt="Del Mar, CA" class="scl-m-img" />
          <div class="scl-m-overlay">
            <span class="scl-m-city">DEL MAR, CA</span>
            <span class="scl-m-project">Modern Attached Louvered Pergola with Integrated LED Lighting</span>
          </div>
        </div>

        <!-- DUPLICATED SET FOR SEAMLESS LOOP -->
        <div class="scl-m-item">
          <img src="/assets/images/socal/mobile/Bel_Air_CA.jpg" alt="Bel Air, CA" class="scl-m-img" />
          <div class="scl-m-overlay">
            <span class="scl-m-city">BEL AIR, CA</span>
            <span class="scl-m-project">Motorized Louvered Pergola with Free Leaf-Pattern Privacy Screen</span>
          </div>
        </div>
        <div class="scl-m-item">
          <img src="/assets/images/socal/mobile/Pasadena_CA.jpg" alt="Pasadena, CA" class="scl-m-img" />
          <div class="scl-m-overlay">
            <span class="scl-m-city">PASADENA, CA</span>
            <span class="scl-m-project">Motorized Louvered Pergola with Free Leaf-Pattern Privacy Screen</span>
          </div>
        </div>
        <div class="scl-m-item">
          <img src="/assets/images/socal/mobile/Sherman_Oaks_CA.jpg" alt="Sherman Oaks, CA" class="scl-m-img" />
          <div class="scl-m-overlay">
            <span class="scl-m-city">SHERMAN OAKS, CA</span>
            <span class="scl-m-project">Aluminum Pergola with Integrated Side Privacy Slats</span>
          </div>
        </div>
        <div class="scl-m-item">
          <img src="/assets/images/socal/mobile/Del_Mar_CA.jpg" alt="Del Mar, CA" class="scl-m-img" />
          <div class="scl-m-overlay">
            <span class="scl-m-city">DEL MAR, CA</span>
            <span class="scl-m-project">Modern Attached Louvered Pergola with Integrated LED Lighting</span>
          </div>
        </div>

      </div>
    </div>
  </div>

</section>

<style>
  .socal-section {
    width: 100%;
    background-color: #F5F9FF;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 100px 0 0 0;
    box-sizing: border-box;
    overflow: hidden; /* Important for slider */
  }

  .scl-mobile {
    display: none;
  }

  .scl-desktop {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  /* --- DESKTOP STYLES --- */
  .socal-header {
    width: 100%;
    max-width: 1400px;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 20px;
    margin-bottom: 60px;
    box-sizing: border-box;
  }
  .socal-subtitle { display: flex; align-items: center; justify-content: center; gap: 10px; }
  .socal-arrow { width: 24px; height: auto; }
  .socal-blue-italic {
    color: #2C65B0; font-family: 'Raleway', sans-serif; font-size: 26px;
    font-style: italic; font-weight: 800; line-height: 18px;
    letter-spacing: 2.64px; text-transform: uppercase;
  }
  .socal-dark-italic {
    color: #14110E; font-family: 'Raleway', sans-serif; font-size: 26px;
    font-style: italic; font-weight: 800; line-height: 18px;
    letter-spacing: 2.64px; text-transform: uppercase;
  }
  .socal-title {
    color: #14110E; font-family: 'Raleway', sans-serif; font-size: 45px;
    font-weight: 800; line-height: 45px; letter-spacing: -0.9px;
    margin: 0; max-width: 1350px;
  }
  .socal-blue-title { color: #2C65B0; }
  .socal-desc {
    color: #635C57; font-family: 'Raleway', sans-serif; font-size: 16px;
    font-weight: 400; line-height: 26px; margin: 0; max-width: 924px;
  }

  .socal-grid {
    display: grid; width: 100%; grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto auto; gap: 14px;
  }
  .socal-item { position: relative; border-radius: 0; overflow: hidden; display: flex; }
  .socal-item img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .socal-overlay {
    position: absolute; bottom: 0; left: 0; width: 100%;
    padding: 60px 30px 20px 30px; background: transparent;
    display: flex; flex-direction: column; gap: 8px; box-sizing: border-box;
  }
  .socal-city {
    color: rgba(255, 255, 255, 0.80); font-family: 'Raleway', sans-serif;
    font-size: 12px; font-weight: 500; line-height: 16px;
    letter-spacing: 1.2px; text-transform: uppercase;
  }
  .socal-project {
    color: #FFF; font-family: 'Raleway', sans-serif; font-size: 20px;
    font-weight: 400; line-height: 28px;
  }
  .item-belair { grid-column: 1 / 2; grid-row: 1 / 3; min-height: 500px; }
  .item-pasadena { grid-column: 2 / 3; grid-row: 1 / 2; min-height: 250px; }
  .item-sherman { grid-column: 2 / 3; grid-row: 2 / 3; min-height: 250px; }
  .item-delmar { grid-column: 1 / 3; grid-row: 3 / 4; min-height: 350px; }

  /* --- MOBILE STYLES (Exclusive Block) --- */
  @media (max-width: 1200px) {
    .scl-desktop {
      display: none !important;
    }
    
    .scl-mobile {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      padding-bottom: 0;
    }

    .socal-section {
      padding: 60px 0 0 0;
    }

    .scl-m-header {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-bottom: 30px;
      padding: 0 20px;
    }

    .scl-m-badge {
      width: 151px;
      height: 31px;
      background-color: #2C65B0;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 4px;
      margin-bottom: 15px;
    }

    .scl-m-socal {
      color: #EAC848;
      font-family: 'Raleway', sans-serif;
      font-size: 12.668px;
      font-style: italic;
      font-weight: 800;
      line-height: 12.668px;
      letter-spacing: 1.858px;
      text-transform: uppercase;
    }

    .scl-m-living {
      color: #FFF;
      font-family: 'Raleway', sans-serif;
      font-size: 12.668px;
      font-style: italic;
      font-weight: 800;
      line-height: 12.668px;
      letter-spacing: 1.858px;
      text-transform: uppercase;
    }

    .scl-m-title {
      width: 363px;
      height: 93px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      color: #14110E;
      text-align: center;
      font-family: 'Raleway', sans-serif;
      font-size: 24px;
      font-style: normal;
      font-weight: 800;
      line-height: 27px;
      letter-spacing: -0.9px;
      margin: 0;
    }

    .scl-m-blue-title {
      color: #2C65B0;
    }

    /* Infinite Marquee Slider */
    .scl-m-slider {
      width: 100%;
      overflow: hidden; /* Hide anything outside the viewport */
    }

    .scl-m-track {
      display: flex;
      width: fit-content;
      animation: marquee 30s linear infinite; /* Smooth, continuous loop */
    }

    .scl-m-track:hover {
      animation-play-state: paused; /* Pause on touch/hold */
    }

    .scl-m-item {
      position: relative;
      width: 320px;
      height: 480px;
      margin-right: 15px; /* Gap between cards */
      flex-shrink: 0;
      display: flex;
      border-radius: 4px;
      overflow: hidden;
    }

    .scl-m-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .scl-m-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      padding: 60px 20px 20px 20px;
      background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%);
      display: flex;
      flex-direction: column;
      gap: 6px;
      box-sizing: border-box;
    }

    .scl-m-city {
      color: rgba(255, 255, 255, 0.80);
      font-family: 'Raleway', sans-serif;
      font-size: 12px;
      font-style: normal;
      font-weight: 500;
      line-height: 16px;
      letter-spacing: 1.2px;
      text-transform: uppercase;
    }

    .scl-m-project {
      color: #FFF;
      font-family: 'Raleway', sans-serif;
      font-size: 18px;
      font-style: normal;
      font-weight: 400;
      line-height: 28px;
    }
  }

  /* The animation moves the track left by exactly 50% (one full set of 4 cards) */
  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
