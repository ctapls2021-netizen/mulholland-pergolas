---
---
<section class="section-two">
  <div class="s2-container">
    
    <div class="s2-left">
      <div class="s2-left-content">
        <h2 class="s2-title">
          Advanced gate engineering<br/>& smart automation
        </h2>
        <p class="s2-subtitle">
          Custom-designed driveway gates, whisper-quiet motors,
          and smart access control.
        </p>
      </div>
      <!-- Button overflows container -->
      <a href="#estimate" class="s2-button desktop-only">
        <img src="/assets/images/icon_secure.svg" alt="Secure Shield" class="s2-btn-icon" />
        <span class="s2-btn-text-gold">SECURE</span>
        <span class="s2-btn-text-white">ENTRANCES</span>
      </a>
    </div>

    <!-- Mobile ONLY Images -->
    <div class="s2-mobile-images">
      <div class="s2-img-wrapper">
        <img src="/assets/images/section2/movil/Advanced gate engineering smart automation.jpg" class="s2-bg-img" alt="Advanced gate engineering" />
        <div class="s2-overlay">
          <img src="/assets/images/section2/movil/line mobile.svg" class="s2-line" alt="" />
          <img src="/assets/images/section2/movil/Advanced gate engineering -smart automation.jpg" class="s2-card-img" alt="IST Sliding Technology" />
        </div>
      </div>
    </div>

    <div class="s2-right">
      <p class="s2-desc desktop-only">
        Enhance security and make a lasting first impression with a custom aluminum gate.<br/>
        Every system is built to fit your property and engineered with rust-proof, maintenance-free materials.
      </p>

      <div class="s2-features">
        <div class="s2-feature-item">
          <img src="/assets/images/section2/Patented IST™ Sliding Technology.svg" alt="IST Sliding Technology" class="s2-icon" />
          <div class="s2-feature-text-block">
            <h3>Patented IST&trade; Sliding Technology</h3>
            <p>Hides all bulky tracks and rollers inside the gate frame for a clean, silent, hovering slide.</p>
          </div>
        </div>

        <div class="s2-feature-item">
          <img src="/assets/images/section2/Smart Automation Integration.svg" alt="Smart Automation Integration" class="s2-icon" />
          <div class="s2-feature-text-block">
            <h3>Smart Automation Integration</h3>
            <p>Seamlessly integrated with remote keypads, smartphone apps, and telephone intercom systems for effortless entry.</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
 /* Primary layout container */
 .section-two {
 width: 100%;
 display: flex;
 justify-content: center;
 background-color: transparent;
 position: relative;
 padding-top: 0;
 margin-bottom: 0;
 z-index: 10;
 }

 .s2-container {
 width: 100%;
 max-width: 1583px; 
 min-height: 351px;
 background: #ffffff;
 display: flex;
 position: relative;
 padding: 55px 60px 40px 0; 
 box-sizing: border-box;
 }

 .s2-left {
 flex: 1.2;
 max-width: 669px; /* Constrain width to ensure layout integrity */
 padding-right: 40px;
 text-align: center;
 position: relative;
 display: flex;
 flex-direction: column;
 justify-content: center;
 }

 .s2-left-content {
 margin-bottom: 20px;
 }

 .s2-title {
 font-family: 'Raleway', sans-serif;
 font-weight: 800;
 font-size: clamp(28px, 2.8vw, 45px);
 line-height: 1.1;
 letter-spacing: -0.09px;
 color: #000000;
 margin: 0 0 20px 0;
 }

 .s2-subtitle {
 font-family: 'Raleway', sans-serif;
 font-weight: 500;
 font-size: clamp(16px, 1.5vw, 22px);
 line-height: 1.3;
 color: #000000;
 margin: 0;
 }

 /* ─── RIGHT COLUMN ────────────────────────────────────── */
 .s2-right {
 flex: 1.5;
 display: flex;
 flex-direction: column;
 justify-content: center;
 padding-left: 20px;
 }

 .s2-desc {
 font-family: 'Raleway', sans-serif;
 font-weight: 400;
 font-size: 16px;
 line-height: 26px;
 color: #635C57;
 margin: 0 0 30px 0;
 max-width: 800px;
 }

 .s2-features {
 display: flex;
 flex-direction: column;
 gap: 24px;
 }

 .s2-feature-item {
 display: flex;
 align-items: flex-start;
 gap: 20px;
 }

 .s2-icon {
 width: 48px;
 height: auto;
 flex-shrink: 0;
 }

 .s2-feature-text-block h3 {
 font-family: 'Raleway', sans-serif;
 font-weight: 800;
 font-size: 26px;
 line-height: 24px;
 color: #14110E;
 margin: 0 0 8px 0;
 }

 .s2-feature-text-block p {
 font-family: 'Raleway', sans-serif;
 font-weight: 400;
 font-size: 16px;
 line-height: 26px;
 color: #635C57;
 margin: 0;
 max-width: 650px;
 }

 /* ─── BUTTON ──────────────────────────────────────────── */
 .s2-button {
 position: absolute;
 left: 0;
 bottom: -71px; /* Offset placement for overlap effect */
 width: 100%;
 height: 63px;
 background: #2C65B0;
 display: flex;
 align-items: center;
 justify-content: center;
 text-decoration: none;
 gap: 12px;
 transition: background 0.25s;
 }

 .s2-button:hover {
 background: #23518c;
 }

 .s2-btn-icon {
 height: 24px;
 width: auto;
 }

 .s2-btn-text-gold,
 .s2-btn-text-white {
 font-family: 'Raleway', sans-serif;
 font-weight: 800;
 font-style: italic;
 font-size: 18px;
 line-height: 16px;
 letter-spacing: 5px;
 text-transform: uppercase;
 }

 .s2-btn-text-gold {
 color: #EAC848;
 }

 .s2-btn-text-white {
 color: #ffffff;
 }

 .s2-mobile-images {
  display: none;
  }

 /* ─── Responsive ──────────────────────────────────────── */
 @media (max-width: 1200px) {
 .s2-container {
 padding: 40px 40px 40px 0;
 }
 }

  @media (max-width: 768px) {
  .s2-mobile-images {
  display: flex;
  justify-content: center;
  width: 100%;
  margin-top: 30px;
  margin-bottom: 0px; 
  }
  .s2-img-wrapper {
  position: relative;
  width: 100%;
  max-width: 402px;
  display: flex;
  flex-direction: column;
  align-items: center;
  }
  .s2-bg-img {
  width: 100%;
  height: auto;
  display: block;
  }
  .s2-overlay {
  position: relative;
  margin-top: -65%;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  margin-bottom: 56px;
  }
  .s2-line {
  height: 74px;
  width: 15px;
  margin-bottom: -2px; /* Connects seamlessly */
  z-index: 2;
  }
  .s2-card-img {
  width: 224px;
  height: auto;
  z-index: 2;
  box-shadow: 0px 4px 20px rgba(0,0,0,0.1); /* Subtle shadow for overlay */
  }
  .desktop-only {
  display: none !important;
  }

 .s2-container {
 max-width: 100%;
 height: auto;
 flex-direction: column;
 padding-bottom: 40px; 
 }
 .s2-left {
 flex: none;
 width: 100%;
 max-width: 100%;
 margin-bottom: 0;
 padding-right: 0;
 padding-left: 0;
 }
 .s2-left-content {
 padding-left: 60px;
 padding-right: 60px;
 }
 .s2-button {
 position: relative;
 bottom: auto;
 left: 60px;
 width: calc(100% - 120px);
 margin-top: 30px;
 margin-bottom: 40px;
 }
 }

  @media (max-width: 768px) {
  .s2-container {
  padding: 40px 0 0 0;
  }
  .s2-left-content {
  padding-left: 20px;
  padding-right: 20px;
  }
  .s2-title {
  font-size: 24px !important;
  line-height: 28px !important; /* 24px + appropriate spacing */
  }
  .s2-subtitle {
  font-size: 14px !important;
  line-height: 20px !important;
  }
  .s2-feature-text-block h3 {
  font-size: 20px !important;
  line-height: 24px !important;
  }
  .s2-feature-text-block p {
  font-size: 14px !important;
  line-height: 20px !important;
  }
  .s2-left, .s2-right {
  padding: 0 20px;
  }
  .s2-button {
  width: calc(100% - 40px);
  left: 20px;
  margin: 20px 0 30px 0;
  }
  }
</style>
