margin-left: -15px;
height: 300px;
object-fit: cover;
}

.adv-m-features {
align-self: stretch; /* Prevents parent align-items: center from squishing it */
margin: 0 -15px; /* Pulls exactly 15px to both left and right edges */
width: auto; /* Automatically stretches to fill the new margin space */
display: grid;
grid-template-columns: 1fr 1fr;
gap: 30px 15px;
padding: 40px 15px;
background-color: #F8F9FA;
box-sizing: border-box;
}

.adv-m-feature {
display: flex;
flex-direction: column;
align-items: center;
text-align: center;
}

.adv-m-feature-icon {
width: 50px;
height: 50px;
margin-bottom: 15px;
object-fit: contain;
}

.adv-m-feature-title {
color: #14110E;
text-align: center;
font-family: 'Raleway', sans-serif;
font-size: 17px;
font-style: normal;
font-weight: 800;
