}

.adv-m-texts {
display: flex;
flex-direction: column;
align-items: center;
text-align: center;
padding: 0 10px 40px 10px;
}

.adv-m-subtitle {
color: #FFF;
font-family: 'Raleway', sans-serif;
font-size: 12px;
font-weight: 600;
letter-spacing: 2.64px;
text-transform: uppercase;
margin-bottom: 15px;
}

.adv-m-title {
color: #FFF;
font-family: 'Raleway', sans-serif;
font-size: 28px;
font-weight: 800;
line-height: 32px;
letter-spacing: -0.5px;
margin: 0 0 15px 0;
}

