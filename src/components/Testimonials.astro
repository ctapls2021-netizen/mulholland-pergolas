---
// Testimonials.astro
const reviewsData = [
{ platform: 'Google', score: '5.0', logo: 'google-color.png', width: 96, height: 41 },
{ platform: 'Yelp', score: '5.0', logo: 'yelp-color.png', width: 98, height: 46 },
{ platform: 'Houzz', score: '5.0', logo: 'houzz-color.png', width: 125, height: 28 },
{ platform: 'Facebook', score: '4.9', logo: 'facebook-color.png', width: 122, height: 23 }
];

const testimonials = [
{
title: "The ultimate\nbackyard upgrade!",
text: '"We spent years avoiding our backyard in the\nafternoon because the sun was just brutal. We\ncalled Mulholland, and they designed a\ngorgeous motorized louvered pergola for us.\nThe quality is incredible—the louvers rotate\nsilently, and the rain sensor closed the roof\nperfectly during our last storm. Plus, we got\nthe 20% off promotion and they included a\nbeautiful, free laser-cut backdrop screen that\nblocks our neighbor\'s two-story window\nperfectly. Dealing with one team from design\nto installation made the entire process\nseamless."',
name: "Robert & Chloe M",
city: "Pasadena, CA",
verified: "Verified Project: Motorized Louvered Pergola with Free Leaf-Pattern Privacy Screen"
},
{
title: "Perfect for coastal\nsalt air — absolutely\nzero maintenance.",
text: '"Living right on the coast in Del Mar, our old\nwood pergola rotted and warped within three\nyears. We upgraded to Mulholland\'s wood-like\naluminum pergola and it is a night-and-day\ndifference. It looks exactly like natural cedar,\nbut it never fades, warps, or rusts in the salt air.\nWe also took advantage of their 18 Months No\nInterest Financing, which made budgeting a\nbreeze. If you want a high-end pergola built to\nlast, skip the cheap pre-made kits and go with\nMulholland."',
name: "Marcus T.",
city: "Del Mar, CA",
verified: "Verified Project: Wood-Look Aluminum Pergola with Integrated Side Privacy Slats"
},
{
title: "Flawless local\ncraftsmanship from\nfactory to backyard.",
text: '"The fact that they manufacture everything in\ntheir own local factory is why we chose them.\nWe wanted our pergola\'s frame to match the\nexact custom charcoal gray of our home\'s\nwindow trims, and they matched it perfectly.\nThey also handled all the electrical wiring for\nthe integrated LED lights and heaters. Getting\nthe 20% off summer special was a huge bonus,\nand the free 4\'x8\' laser-cut panel we received\nacts as a stunning piece of outdoor art behind\nour BBQ island. Five-star service all around!"',
name: "Elena G.",
city: "Sherman Oaks, CA",
verified: "Verified Project: Modern Attached Louvered Pergola with Integrated LED Lighting"
}
];
---
<section class="test-section" id="testimonials">

<!-- DESKTOP VERSION -->
<div class="test-desktop">
<!-- Top Background Image -->
<div class="test-bg-top"></div>

<div class="test-container">
<!-- White Testimonials Card -->
<div class="test-card-white" data-aos="fade-up">
<!-- Logos Row -->
<div class="test-logos">
{reviewsData.map(r => (
<img src={`/assets/images/testimonials/${r.logo}`} alt={r.platform} class="test-logo" style={`width: ${r.width}px; height: auto;`} />
))}
</div>

<!-- Header Content -->
<div class="test-header">
<div class="test-subtitle">VOICES OF TRUST</div>
<h2 class="test-title">What Your Neighbors Are Saying</h2>
<p class="test-desc">With over 30 years of local manufacturing and installation, we have secured and beautified thousands of Southern California homes.</p>
</div>

<!-- Reviews Grid -->
<div class="test-grid">
{testimonials.map(t => (
<div class="test-col">
<div class="test-stars">
<img src="/assets/images/testimonials/star.svg" alt="5 Stars" class="t-five-stars" />
</div>
<h3 class="t-col-title">{t.title}</h3>
<p class="t-col-text">{t.text}</p>
<div class="t-col-divider"></div>
<div class="t-col-author">
<div class="t-author-name">{t.name}</div>
<div class="t-author-city">{t.city}</div>
</div>
<div class="t-col-verified">
<img src="/assets/images/testimonials/verified.svg" alt="Verified" class="t-ver-icon" />
<span class="t-ver-text">{t.verified}</span>
</div>
</div>
))}
</div>
</div>
</div>

<!-- Bottom Advantage Section -->
<div class="adv-section">
<div class="adv-left">
<span class="adv-subtitle">The Mulholland Advantage</span>
<h2 class="adv-title">Why Southern California Homeowners Choose Mulholland Brand</h2>
<p class="adv-text">We design, manufacture, and install premium custom pergolas under one roof.</p>
</div>
<div class="adv-right">
<img src="/assets/images/testimonials/factory-new.jpg" alt="Mulholland Factory" class="adv-image" />
</div>
</div>
</div>

<!-- MOBILE VERSION -->
<div class="test-mobile">
<div class="tm-card">

<!-- Header -->
<div class="tm-header">
<div class="tm-subtitle">VOICES OF TRUST</div>
<h2 class="tm-title">What Your Neighbors<br/>Are Saying</h2>
</div>

<!-- 2x2 Logos Grid -->
<div class="tm-logos-grid">
<div class="tm-logo-item">
<img src="/assets/images/testimonials/google-color.png" alt="Google" class="tm-logo" style="width: 70px;" />
<span class="tm-score">5.0</span>
</div>
<div class="tm-logo-item">
<img src="/assets/images/testimonials/facebook-color.png" alt="Facebook" class="tm-logo" style="width: 80px;" />
<span class="tm-score">4.9</span>
</div>
<div class="tm-logo-item">
<img src="/assets/images/testimonials/houzz-color.png" alt="Houzz" class="tm-logo" style="width: 80px;" />
<span class="tm-score">5.0</span>
</div>
<div class="tm-logo-item">
<img src="/assets/images/testimonials/yelp-color.png" alt="Yelp" class="tm-logo" style="width: 70px;" />
<span class="tm-score">5.0</span>
</div>
</div>

<!-- Reviews Slider -->
<div class="tm-slider">
{testimonials.map(t => (
<div class="tm-slide">
<h3 class="tm-r-title">{t.title}</h3>
<p class="tm-r-text">{t.text.replace(/\n/g, ' ')}</p>

<div class="tm-r-author">
<div class="tm-r-name">{t.name}</div>
<div class="tm-r-city">{t.city}</div>
</div>
<div class="tm-r-verified">
<img src="/assets/images/testimonials/verified.svg" alt="Verified" class="tm-rv-icon" />
<span class="tm-rv-text">{t.verified}</span>
</div>
</div>
))}
</div>

</div>

<!-- Mobile Bottom Advantage -->
<div class="adv-m-section">
<img src="/assets/images/testimonials/factory-new.jpg" alt="Mulholland Factory" class="adv-m-image-full" />
<div class="adv-m-texts">
<span class="adv-m-subtitle">The Mulholland Advantage</span>
<h2 class="adv-m-title">Why Southern California Homeowners Choose Mulholland Brand</h2>
<p class="adv-m-text">We design, manufacture, and install premium custom pergolas under one roof.</p>
</div>

<!-- 2x2 Features Grid -->
<div class="adv-m-features">
<div class="adv-m-feature" data-aos="fade-up">
<img src="/assets/images/pergolas/features-grid/icon-team.png" alt="Local Team" class="adv-m-feature-icon" />
<h3 class="adv-m-feature-title">One Trusted Local<br/>Team</h3>
<p class="adv-m-feature-text">A single point of contact from<br/>design to manufacturing and final<br/>installation. No third-party<br/>subcontractors or finger-pointing.</p>
</div>
<div class="adv-m-feature" data-aos="fade-up">
<img src="/assets/images/pergolas/features-grid/icon-factory.png" alt="Factory" class="adv-m-feature-icon" />
<h3 class="adv-m-feature-title">Custom-Fabricated<br/>Locally</h3>
<p class="adv-m-feature-text">Every pergola is custom-built to<br/>your patio's exact dimensions in<br/>our local LA factory. No cheap,<br/>flimsy pre-made kits.</p>
</div>
<div class="adv-m-feature" data-aos="fade-up">
<img src="/assets/images/pergolas/features-grid/icon-rustproof.png" alt="Rust-Proof" class="adv-m-feature-icon" />
<h3 class="adv-m-feature-title">Rust-Proof Marine<br/>Aluminum</h3>
<p class="adv-m-feature-text">Fabricated from 6063-T5<br/>architectural aluminum with<br/>a marine-grade powder<br/>coating that never rusts, rots,<br/>warps, or splits.</p>
</div>
<div class="adv-m-feature" data-aos="fade-up">
<img src="/assets/images/pergolas/features-grid/icon-financing.png" alt="Financing" class="adv-m-feature-icon" />
<h3 class="adv-m-feature-title">Flexible 0%<br/>Financing</h3>
<p class="adv-m-feature-text">Take advantage of our 18<br/>Months No Interest<br/>Financing and start your<br/>project today with payments<br/>that fit your budget.</p>
</div>
</div>

<img src="/assets/images/testimonials/The-Mulholland-Advantage.jpg" alt="Mulholland Pergola" class="adv-m-image-full" />
</div>

</div>

</section>

<style>
.test-section {
  position: relative;
  width: 100%;
  background-color: #2C65B0;
  box-sizing: border-box;
}

.test-mobile {
display: none;
}

/* --- DESKTOP STYLES --- */
.test-desktop {
  position: relative;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100px 0 0 0;
  box-sizing: border-box;
}

.test-bg-top {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 550px;
  background-image: url('/assets/images/testimonials/pergola-Mulholland.jpg');
  background-size: cover;
  background-position: center;
  z-index: 0;
}

.test-container {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 1430px;
  display: flex;
  flex-direction: column;
  padding: 0 20px;
  box-sizing: border-box;
}

.test-card-white {
  width: 100%;
  background-color: #FFFFFF;
  border-radius: 8px;
  padding: 60px;
  box-shadow: 0px 20px 40px rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  gap: 50px;
  box-sizing: border-box;
}

.test-logos {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 60px;
}

.test-logo {
  height: auto;
  opacity: 0.8;
}

.test-header {
  text-align: center;
}

.test-subtitle {
  color: #14110E;
  font-family: 'Raleway', sans-serif;
  font-size: 14px;
  font-weight: 800;
  letter-spacing: 3.08px;
  text-transform: uppercase;
  margin-bottom: 20px;
}

.test-title {
  color: #2C65B0;
  font-family: 'Raleway', sans-serif;
  font-size: 45px;
  font-weight: 800;
  line-height: 48px;
  margin: 0 0 20px 0;
}

.test-desc {
  color: #635C57;
  font-family: 'Raleway', sans-serif;
  font-size: 16px;
  font-weight: 500;
  line-height: 24px;
  white-space: normal;
  max-width: 650px;
  margin: 0 auto;
}

.test-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
  width: 100%;
}

.test-col {
  display: flex;
  flex-direction: column;
  background-color: #FDFDFD;
  border: 1px solid #EAEAEA;
  border-radius: 6px;
  padding: 40px 30px;
  height: 100%;
  box-sizing: border-box;
}

.test-stars {
  margin-bottom: 20px;
  display: flex;
}

.t-five-stars {
  width: 120px;
  height: auto;
}

.t-col-title {
  color: #14110E;
  font-family: 'Raleway', sans-serif;
  font-size: 20px;
  font-style: italic;
  font-weight: 800;
  line-height: 28px;
  margin: 0 0 15px 0;
  white-space: pre-line;
}

.t-col-text {
  color: #312C2C;
  font-family: 'Raleway', sans-serif;
  font-size: 14px;
  font-style: italic;
  font-weight: 400;
  line-height: 22px;
  margin: 0 0 30px 0;
  flex: 1;
}

.t-col-divider {
  width: 100%;
  height: 1px;
  background-color: #E5E2DE;
  margin-bottom: 20px;
}

.t-col-author {
  margin-bottom: 15px;
}

.t-author-name {
  color: #2C65B0;
  font-family: 'Raleway', sans-serif;
  font-size: 16px;
  font-weight: 800;
}

.t-author-city {
  color: #2C65B0;
  font-family: 'Raleway', sans-serif;
  font-size: 12px;
  font-weight: 800;
}

.t-col-verified {
  display: flex;
  align-items: flex-start;
  gap: 10px;
}

.t-ver-icon {
  width: 20px;
  height: auto;
  margin-top: 2px;
  filter: brightness(0) saturate(100%) invert(31%) sepia(85%) saturate(763%) hue-rotate(178deg) brightness(97%) contrast(93%);
}

.t-ver-text {
  color: #312C2C;
  font-family: 'Raleway', sans-serif;
  font-size: 12px;
  font-weight: 400;
  line-height: 16px;
}

.adv-section {
  display: flex;
  align-items: stretch;
  width: 100%;
  margin-top: 80px;
  box-sizing: border-box;
}

.adv-left {
  width: 50%;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-left: max(20px, calc((100vw - 1430px) / 2 + 20px));
  padding-right: 60px;
  padding-top: 80px;
  padding-bottom: 80px;
  background-color: #2C65B0;
  box-sizing: border-box;
}

.adv-subtitle {
  color: #FFF;
  font-family: 'Raleway', sans-serif;
  font-size: 12px;
  font-weight: 600;
  line-height: 16px;
  letter-spacing: 2.64px;
  text-transform: uppercase;
  margin-bottom: 20px;
}

.adv-title {
  color: #FFF;
  font-family: 'Raleway', sans-serif;
  font-size: 45px;
  font-weight: 800;
  line-height: 45px;
  letter-spacing: -0.9px;
  margin: 0 0 20px 0;
  max-width: 650px;
}

.adv-text {
  color: #FFF;
  font-family: 'Raleway', sans-serif;
  font-size: 26px;
  font-weight: 400;
  line-height: 30px;
  margin: 0;
  max-width: 544px;
}

.adv-right {
  width: 50%;
  flex-shrink: 0;
  overflow: hidden;
}

.adv-image {
  width: 100%;
  height: 100%;
  min-height: 478px;
  object-fit: cover;
  display: block;
}

/* --- DESKTOP 1024-1200px TWEAKS --- */
@media (max-width: 1200px) and (min-width: 1024px) {
  .test-section {
    margin-top: 20px;
  }
  .test-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .test-col:nth-child(3) {
    display: none;
  }
  .test-logos {
    gap: 30px;
    flex-wrap: wrap;
  }
}

/* --- MOBILE STYLES (Exclusive Block) --- */
@media (max-width: 1023px) {
.test-desktop {
display: none !important;
}
.test-mobile {
display: flex;
flex-direction: column;
width: 100%;
padding: 30px 15px 0 15px; /* 30px top padding */
box-sizing: border-box;
}

/* Mobile White Card */
.tm-card {
background-color: #FFF;
border-radius: 12px;
padding: 40px 20px;
display: flex;
flex-direction: column;
align-items: center;
width: 100%;
max-width: 100%;
box-sizing: border-box;
box-shadow: 0 10px 30px rgba(0,0,0,0.1);
overflow: hidden; /* Prevents slider from breaking width */
}

.tm-header {
text-align: center;
margin-bottom: 30px;
}

.tm-subtitle {
color: #312C2C;
font-family: 'Raleway', sans-serif;
font-size: 12px;
font-weight: 600;
line-height: 16px;
letter-spacing: 2.64px;
text-transform: uppercase;
margin-bottom: 10px;
}

.tm-title {
display: flex;
flex-direction: column;
justify-content: center;
width: 262px;
height: 45px;
margin: 0 auto;
color: #2C65B0;
text-align: center;
font-family: 'Raleway', sans-serif;
font-size: 24px;
font-weight: 800;
line-height: 27px;
letter-spacing: -0.9px;
}

/* 2x2 Logos Grid */
.tm-logos-grid {
display: grid;
grid-template-columns: 1fr 1fr;
grid-template-rows: auto auto;
gap: 20px 10px;
width: 100%;
max-width: 320px;
margin-bottom: 40px;
}

.tm-logo-item {
display: flex;
align-items: center;
justify-content: center;
gap: 8px; /* Slightly reduced gap so logos don't overflow */
}

.tm-logo {
object-fit: contain;
}

.tm-score {
color: #14110E;
font-family: 'Raleway', sans-serif;
font-size: 20px; /* Reduced from 24px to fit better */
font-weight: 800;
}

/* Slider Wrapper */
.tm-slider {
display: flex;
flex-direction: row;
flex-wrap: nowrap; /* Ensures children stay in a row */
overflow-x: auto;
scroll-snap-type: x mandatory;
width: 100%;
padding-bottom: 20px;
scrollbar-width: none;
-ms-overflow-style: none;
}

.tm-slider::-webkit-scrollbar {
display: none;
}

.tm-slide {
min-width: 100%;
max-width: 100%;
flex: 0 0 100%;
scroll-snap-align: center;
display: flex;
flex-direction: column;
align-items: center;
text-align: center;
box-sizing: border-box;
padding: 0 10px; /* Internal padding instead of parent gap */
}

.tm-r-title {
width: 299px;
color: #312C2C;
text-align: center;
font-family: 'Raleway', sans-serif;
font-size: 30px;
font-style: italic;
font-weight: 800;
line-height: 27.5px;
margin: 0 auto 20px auto;
white-space: pre-wrap;
}

.tm-r-text {
width: 331px;
max-width: 100%;
color: #312C2C;
text-align: center;
font-family: 'Raleway', sans-serif;
font-size: 18px;
font-style: italic;
font-weight: 400;
line-height: 20px;
margin: 0 auto 30px auto;
white-space: normal; /* Fixed: normal prevents hard line breaks from the \n in text array */
}

.tm-r-author {
display: flex;
flex-direction: column;
justify-content: center;
align-items: center; /* Center author text */
height: 37px;
margin: 0 auto 15px auto;
}

.tm-r-name {
color: #2C65B0;
text-align: center;
font-family: 'Raleway', sans-serif;
font-size: 14px;
font-style: normal;
font-weight: 800;
line-height: 13px;
}

.tm-r-city {
color: #2C65B0;
text-align: center;
font-family: 'Raleway', sans-serif;
font-size: 11px;
font-style: normal;
font-weight: 800;
line-height: 13px;
}

.tm-r-verified {
display: flex;
align-items: flex-start;
justify-content: flex-start; /* Icon and text to the left */
gap: 8px;
text-align: left;
width: 331px; /* Matches exactly the width of the testimonial text */
max-width: 100%;
margin: 0 auto; /* Centers the block itself, so its left edge aligns with the text above it */
}

.tm-rv-icon {
width: 27px;
height: 27px;
flex-shrink: 0;
filter: brightness(0) saturate(100%) invert(31%) sepia(85%) saturate(763%) hue-rotate(178deg) brightness(97%) contrast(93%);
}

.tm-rv-text {
color: #312C2C;
font-family: 'Raleway', sans-serif;
font-size: 14px;
font-style: normal;
font-weight: 500;
line-height: 16px;
width: 243px;
}

/* Mobile Advantage Section */
.adv-m-section {
display: flex;
flex-direction: column;
align-items: center;
width: 100%;
box-sizing: border-box;
margin-top: 30px; /* 30px gap below the white card */
}

.adv-m-image-full {
