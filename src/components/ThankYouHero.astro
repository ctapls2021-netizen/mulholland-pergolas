<section class="thank-you-hero">
  <div class="hero-content">
    <h1>Thank You!</h1>
    <h2>Your Request Has Been Received</h2>
    <p>We have received your contact details and a Mulholland representative will reach out to you shortly.</p>
  </div>
</section>

<style>
  .thank-you-hero {
    position: relative;
    width: 100%;
    height: 556px;
    display: flex;
    align-items: center;
    background-image: url('/assets/images/thank-you/Mulhollandbrand-.jpg');
    background-size: cover;
    background-position: center;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
    color: white;
    text-align: left;
    width: 100%;
  }

  @media (min-width: 768px) {
    .hero-content {
      padding-left: 10%;
      margin: 0;
    }
  }

  .hero-content h1 {
    display: flex;
    width: 100%;
    max-width: 777px;
    min-height: 52px;
    flex-direction: column;
    justify-content: center;
    color: #FFF;
    font-family: 'Raleway', sans-serif;
    font-size: 45px;
    font-style: normal;
    font-weight: 800;
    line-height: 45px;
    letter-spacing: -0.9px;
    margin-bottom: 0.5rem;
    margin-top: 0;
  }

  .hero-content h2 {
    display: flex;
    width: 100%;
    max-width: 777px;
    min-height: 45px;
    flex-direction: column;
    justify-content: center;
    color: #FFF;
    font-family: 'Raleway', sans-serif;
    font-size: 24px;
    font-style: normal;
    font-weight: 800;
    line-height: 1.2em;
    letter-spacing: -0.9px;
    margin-bottom: 1.5rem;
    margin-top: 0;
  }

  .hero-content p {
    width: 100%;
    max-width: 597px;
    min-height: 33px;
    color: #FFF;
    font-family: 'Raleway', sans-serif;
    font-size: 22px;
    font-style: normal;
    font-weight: 500;
    line-height: 28px;
    margin: 0;
  }
</style>
