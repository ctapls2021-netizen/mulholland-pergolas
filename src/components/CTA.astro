---
// CTA.astro
---
<section class="cta-section" id="estimate">
  <div class="cta-left">
    <div class="cta-left-content">
      <h2 class="cta-title">Get your free on-<br class="mobile-break" />site estimate</h2>
      
      <p class="cta-desc">
        Tell us about your property and a Mulholland project<br class="mobile-break" />
        designer will reach out to schedule a complimentary,<br class="mobile-break" />
        no-pressure on-site consultation.
      </p>

      <div class="cta-blue-box">
        <span class="cta-box-gold">SUMMER</span>&nbsp;<span class="cta-box-white">SLOTS FILLING QUICKLY</span>
      </div>

      <div class="cta-call-block">
        <a href="tel:8005625770" class="cta-phone-link">
          <img src="/assets/images/pergolas/cta/phone.svg" alt="Phone" class="cta-phone-icon desktop-icon" />
          <img src="/assets/images/cta/phone-call-white.svg" alt="Phone" class="cta-phone-icon mobile-icon" />
          CALL (800) 562-5770
        </a>
        <div class="cta-verify-text">TO VERIFY PRODUCTION AVAILABILITY</div>
      </div>
      
      <p class="cta-restrictions">
        *Certain restrictions may apply, call for details.
      </p>
    </div>
  </div>

  <div class="cta-right">
    <form class="cta-form" action="#" method="POST">
      <div class="form-row">
        <div class="form-group">
          <label for="fullName">Full Name</label>
          <input type="text" id="fullName" name="fullName" placeholder="Jane Doe" required />
        </div>
        <div class="form-group">
          <label for="phone">Phone Number</label>
          <input type="tel" id="phone" name="phone" placeholder="(310) 555-0123" required />
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" placeholder="jane@email.com" required />
        </div>
        <div class="form-group">
          <label for="zip">ZIP Code</label>
          <input type="text" id="zip" name="zip" placeholder="90210" required />
        </div>
      </div>

      <div class="form-group">
        <label for="interest">What are you interested in?</label>
        <select id="interest" name="interest" required>
          <option value="" disabled selected hidden>Select an option</option>
          <option value="pergola">Custom Pergola</option>
          <option value="gate">Driveway Gate</option>
          <option value="fence">Perimeter Fencing</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div class="form-group">
        <label for="timeline">Project Timeline</label>
        <select id="timeline" name="timeline" required>
          <option value="" disabled selected hidden>Select a timeline</option>
          <option value="immediate">Immediately</option>
          <option value="1-3months">1-3 Months</option>
          <option value="3+months">3+ Months</option>
          <option value="planning">Just Planning</option>
        </select>
      </div>

      <button type="submit" class="cta-submit-btn">
        <span class="btn-text-part1">Request Free</span>&nbsp;<span class="btn-text-part2">On-Site Estimate</span>
      </button>

      <p class="cta-privacy">
        No obligation. We respect your privacy and never share your information.
      </p>
    </form>
  </div>
</section>

<style>
  .cta-section {
    width: 100%;
    display: flex;
    min-height: 693px;
  }

  /* ─── LEFT SIDE ─────────────────────────────────────────── */
  .cta-left {
    flex: 1;
    background-color: #F5F9FF;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 20px;
    box-sizing: border-box;
  }

  .cta-left-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px; /* Space between blocks */
  }

  .cta-title {
    width: 439px;
    height: 124px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: #14110E;
    text-align: center;
    font-family: 'Raleway', sans-serif;
    font-size: 45px;
    font-style: normal;
    font-weight: 800;
    line-height: 50px;
    letter-spacing: -1.2px;
    margin: 0;
  }

  .cta-desc {
    width: 447px;
    height: 72px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: #14110E;
    text-align: center;
    font-family: 'Raleway', sans-serif;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 26px;
    margin: 0;
  }

  .cta-blue-box {
    width: 412px;
    height: 50px;
    background: #2C65B0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 10px 0;
  }

  .cta-box-gold {
    color: #EAC848;
    text-align: center;
    font-family: 'Raleway', sans-serif;
    font-size: 18px;
    font-style: italic;
    font-weight: 800;
    line-height: 18px;
    letter-spacing: 2.64px;
    text-transform: uppercase;
  }

  .cta-box-white {
    color: #FFF;
    font-family: 'Raleway', sans-serif;
    font-size: 18px;
    font-style: italic;
    font-weight: 800;
    line-height: 18px;
    letter-spacing: 2.64px;
    text-transform: uppercase;
  }

  .mobile-break {
    display: none;
  }

  .cta-call-block {
    width: 409px;
    height: 92px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: 0;
  }

  .cta-phone-link {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #14110E;
    text-align: center;
    font-family: 'Raleway', sans-serif;
    font-size: 26px;
    font-style: normal;
    font-weight: 800;
    line-height: 23px;
    text-decoration: none;
    margin-bottom: 5px;
  }

  .cta-phone-icon {
    width: 20px;
    height: auto;
  }

  .mobile-icon {
    display: none;
  }

  .cta-verify-text {
    color: #14110E;
    font-family: 'Raleway', sans-serif;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 23px;
  }

  .cta-restrictions {
    color: #14110E;
    text-align: center;
    font-family: 'Raleway', sans-serif;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 26px;
    margin: -25px 0 0 0; /* Increased negative top margin to pull it even closer */
  }

  /* ─── RIGHT SIDE (FORM) ────────────────────────────────── */
  .cta-right {
    flex: 1;
    border: 1px solid #ADADAD;
    background: linear-gradient(180deg, #5E97D5 0%, #4467AB 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 40px;
    box-sizing: border-box;
  }

  .cta-form {
    width: 100%;
    max-width: 537px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-row {
    display: flex;
    gap: 20px;
  }

  .form-group {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cta-form label {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 14px;
    line-height: 14px;
    color: #FFFFFF;
  }

  .cta-form input,
  .cta-form select {
    width: 100%;
    height: 48px;
    background: #FFFFFF;
    border: 1px solid #E5E2DE;
    border-radius: 4px;
    padding: 0 15px;
    box-sizing: border-box;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: #14110E;
  }

  .cta-form input::placeholder {
    color: #14110E;
    opacity: 0.7;
  }

  .cta-submit-btn {
    width: 100%;
    height: 56px;
    background-color: #EAC848;
    color: #14110E;
    border: none;
    border-radius: 4px;
    font-family: 'Raleway', sans-serif;
    font-weight: 800;
    font-size: 18px;
    line-height: 24px;
    cursor: pointer;
    margin-top: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s;
  }

  .cta-submit-btn:hover {
    background-color: #d6b438;
  }

  .btn-text-part1, .btn-text-part2 {
    color: inherit;
  }

  .cta-privacy {
    text-align: center;
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 12px;
    line-height: 18px;
    color: #FFFFFF;
    margin: 5px 0 0 0;
  }

  /* ─── RESPONSIVE ────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .mobile-break {
      display: block;
    }

    .desktop-icon {
      display: none;
    }

    .mobile-icon {
      display: block;
    }

    .cta-section {
      flex-direction: column;
    }
    
    .cta-left {
      background-image: url('/assets/images/cta/pergola-cta-mobile.jpg');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      min-height: 384px;
      padding: 40px 15px; /* Adjust padding for mobile */
      box-sizing: border-box;
    }

    .cta-left-content {
      gap: 15px; /* Tighter gap for mobile */
    }

    .cta-title {
      color: #FFF;
      font-size: 32px; /* Scale down for mobile */
      line-height: 36px;
      height: auto;
      width: 100%;
    }

    .cta-desc {
      color: #FFF;
      font-size: 14px; /* Scale down for mobile */
      line-height: 22px;
      height: auto;
      width: 100%;
    }

    .cta-blue-box {
      width: 100%;
      max-width: 339px;
      white-space: nowrap;
    }

    .cta-box-gold, .cta-box-white {
      font-size: 12px;
      letter-spacing: 1px;
    }

    .cta-call-block {
      width: 339px;
      height: 92px;
      margin-top: 5px;
    }

    .cta-phone-link {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: center;
      gap: 10px;
      color: #FFF;
      font-family: 'Raleway', sans-serif;
      font-size: 26px;
      font-style: normal;
      font-weight: 800;
      line-height: 23px; /* 88.462% */
    }
    
    .cta-phone-icon {
      filter: none; /* Removed the invert filter since we have a dedicated icon now */
      width: 22px;
      height: 22px;
      flex-shrink: 0;
    }

    .cta-verify-text {
      color: #FFF;
      font-family: 'Raleway', sans-serif;
      font-size: 16px;
      font-style: normal;
      font-weight: 400;
      line-height: 23px;
    }

    .cta-restrictions {
      display: flex;
      width: 329px;
      height: 16px;
      flex-direction: column;
      justify-content: center;
      color: #FFF;
      text-align: center;
      font-family: 'Raleway', sans-serif;
      font-size: 14px;
      font-style: normal;
      font-weight: 400;
      line-height: 26px; /* 185.714% */
      margin: -15px 0 0 0; /* Pulled it even closer with negative margin */
    }

    .cta-right {
      background: #F5F9FF;
      padding: 40px 20px; /* Adjusted padding for smaller screens */
    }

    .cta-form label {
      color: #14110E;
      font-family: 'Raleway', sans-serif;
      font-size: 18px;
      font-style: normal;
      font-weight: 800;
      line-height: 20px; /* 111.111% */
    }

    .cta-privacy {
      color: #14110E;
    }

    .cta-submit-btn {
      background-color: #2C65B0;
    }

    .btn-text-part1 {
      color: #EAC848;
    }

    .btn-text-part2 {
      color: #FFFFFF;
    }

    .cta-submit-btn:hover {
      background-color: #23528f; /* Slightly darker blue on hover */
    }

    .form-row {
      flex-direction: column;
    }
  }
</style>
