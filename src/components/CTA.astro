---
---
<section class="cta-section" id="estimate">
  <div class="cta-left">
    <div class="cta-left-content">
      <div class="cta-subtitle">
        <span class="cta-subtitle-gold">FREE</span> <span class="cta-subtitle-white">CONSULTATION</span>
      </div>
      
      <h2 class="cta-desktop-title-final">Get your free on-<br/>site estimate</h2>
      <h2 class="cta-mobile-title-final">Get your free<br/>on-site estimate</h2>
      
      <p class="cta-desc">
        Tell us about your property and a Mulholland project<br/>
        designer will reach out to schedule a complimentary,<br/>
        no-pressure on-site consultation.
      </p>

      <div class="cta-contact-wrapper">
        <div class="cta-contact-box">
          <span class="cta-contact-text">Prefer to speak to a project designer?</span>
          <img src="/assets/images/cta/Prefer to speak to a project designer.svg" alt="Designer icon" class="cta-designer-icon" />
        </div>
        <a href="tel:8005625770" class="cta-phone-link">
          <img src="/assets/images/cta/phone contact.svg" alt="Phone" class="cta-phone-icon" />
          (800) 562-5770
        </a>
      </div>
    </div>
  </div>

  <div class="cta-right">
    <form class="cta-form" action="#" method="POST">
      <div class="form-row">
        <div class="form-group">
          <label for="fullName">Full Name</label>
          <input type="text" id="fullName" name="fullName" placeholder="Jane Doe" required />
        </div>
        <div class="form-group">
          <label for="phone">Phone Number</label>
          <input type="tel" id="phone" name="phone" placeholder="(310) 555-0123" required />
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" placeholder="jane@email.com" required />
        </div>
        <div class="form-group">
          <label for="zip">ZIP Code</label>
          <input type="text" id="zip" name="zip" placeholder="90210" required />
        </div>
      </div>

      <div class="form-group">
        <label for="interest">What are you interested in?</label>
        <select id="interest" name="interest" required>
          <option value="" disabled selected hidden>Select an option</option>
          <option value="gate">Driveway Gate</option>
          <option value="fence">Perimeter Fencing</option>
          <option value="both">Both Gate & Fence</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div class="form-group">
        <label for="timeline">Project Timeline</label>
        <select id="timeline" name="timeline" required>
          <option value="" disabled selected hidden>Select a timeline</option>
          <option value="immediate">Immediately</option>
          <option value="1-3months">1-3 Months</option>
          <option value="3+months">3+ Months</option>
          <option value="planning">Just Planning</option>
        </select>
      </div>

      <button type="submit" class="cta-submit-btn">
        Request <span class="cta-btn-gold">Free</span> On-Site Estimate
      </button>

      <p class="cta-privacy">
        No obligation. We respect your privacy and<br class="cta-privacy-mobile-br"/>
        never share your information.
      </p>
    </form>
  </div>
</section>

<style>
 .cta-section {
 width: 100%;
 display: flex;
 min-height: 800px;
 }

 /* ─── LEFT SIDE ─────────────────────────────────────────── */
 .cta-left {
 flex: 1;
 position: relative;
 background-image: url('/assets/images/cta/Mulhollandbrand-.webp');
 background-size: cover;
 background-position: center;
 display: flex;
 align-items: center;
 justify-content: center;
 padding: 60px 40px;
 }

 .cta-left-content {
 position: relative;
 z-index: 2;
 max-width: 500px;
 width: 100%;
 display: flex;
 flex-direction: column;
 align-items: flex-start;
 }

 .cta-subtitle {
 width: 291px;
 height: 50px;
 background-color: #2C65B0;
 display: flex;
 align-items: center;
 justify-content: center;
 margin-bottom: 30px;
 }

 .cta-subtitle-gold {
 font-family: 'Raleway', sans-serif;
 font-weight: 800; /* Bold */
 font-style: italic;
 font-size: 18px;
 line-height: 18px;
 letter-spacing: 2.64px;
 color: #EAC848;
 margin-right: 8px;
 text-transform: uppercase;
 }

 .cta-subtitle-white {
 font-family: 'Raleway', sans-serif;
 font-weight: 800; /* Bold */
 font-style: italic;
 font-size: 18px;
 line-height: 18px;
 letter-spacing: 2.64px;
 color: #ffffff;
 text-transform: uppercase;
 }

  .cta-desktop-title-final {
  font-family: 'Raleway', sans-serif;
  font-weight: 800; /* Bold */
  font-size: 45px;
  line-height: 50px;
  letter-spacing: -1.2px;
  color: #ffffff;
  margin: 0 0 25px 0;
  }

  .cta-mobile-title-final {
  display: none;
  font-family: 'Raleway', sans-serif;
  font-weight: 800; /* Bold */
  color: #ffffff;
  }

 .cta-desc {
 font-family: 'Raleway', sans-serif;
 font-weight: 400; /* Regular */
 font-size: 16px;
 line-height: 26px;
 color: #ffffff;
 text-align: right; /* Default for non-desktop if needed, but we override for desktop */
 width: 100%;
 margin: 0 0 35px 0;
 }

 @media (min-width: 1201px) {
   .cta-desc {
     text-align: left !important;
   }
 }

 .cta-contact-wrapper {
 display: flex;
 flex-direction: column;
 align-items: center; /* Center the phone link relative to the box */
 width: fit-content;
 }

 .cta-contact-box {
 background-color: rgba(20, 17, 14, 0.5); /* #14110E at 50% */
 height: 33px;
 padding: 0 25px;
 display: flex;
 align-items: center;
 gap: 25px;
 margin-bottom: 20px;
 }

 .cta-contact-text {
 font-family: 'Inter', sans-serif;
 font-weight: 400; /* Regular */
 font-size: 14px;
 line-height: 20px;
 color: #ffffff;
 }

 .cta-designer-icon {
 width: 39px;
 height: 39px;
 flex-shrink: 0;
 transform: translateY(-10px);
 }

 .cta-phone-link {
 display: flex;
 align-items: center;
 gap: 15px;
 font-family: 'Inter', sans-serif;
 font-weight: 800; /* Bold */
 font-size: 24px;
 line-height: 32px;
 color: #ffffff;
 text-decoration: none;
 }

 .cta-phone-icon {
 width: 24px;
 height: auto;
 }

 /* ─── RIGHT SIDE (FORM) ────────────────────────────────── */
 .cta-right {
 flex: 1;
 background-color: #F5F9FF;
 display: flex;
 align-items: center;
 justify-content: center;
 padding: 60px 40px;
 }

 .cta-form {
 width: 100%;
 max-width: 537px;
 display: flex;
 flex-direction: column;
 gap: 25px;
 }

 .form-row {
 display: flex;
 gap: 25px;
 }

 .form-row .form-group {
 flex: 1;
 }

 .form-group {
 display: flex;
 flex-direction: column;
 gap: 10px;
 }

 .form-group label {
 font-family: 'Raleway', sans-serif;
 font-weight: 800; /* Bold */
 font-size: 18px;
 line-height: 20px;
 color: #14110E;
 }

 .form-group input,
 .form-group select {
 width: 100%;
 height: 46px;
 background-color: #ffffff;
 border: 1px solid #E5E2DE;
 border-radius: 4px;
 padding: 0 15px;
 font-family: 'Inter', sans-serif;
 font-weight: 400; /* Regular */
 font-size: 14px;
 color: #14110E;
 }

 .form-group input::placeholder,
 .form-group select:invalid {
 color: #635C57;
 }

 .cta-submit-btn {
 width: 100%;
 height: 48px;
 background-color: #2C65B0;
 border: none;
 border-radius: 4px;
 font-family: 'Inter', sans-serif; /* Fallback for button */
 font-size: 16px;
 font-weight: 600;
 color: #ffffff;
 cursor: pointer;
 transition: background-color 0.2s ease;
 margin-top: 10px;
 }

 .cta-submit-btn:hover {
 background-color: #22518c;
 }

 .cta-btn-gold {
 color: #EAC848;
 }

  .cta-privacy {
  font-family: 'Raleway', sans-serif;
  font-weight: 400; /* Regular */
  font-size: 12px;
  line-height: 16px;
  color: #635C57;
  text-align: center;
  margin: -10px 0 0 0; /* Pull slightly closer to button */
  }

  .cta-privacy-mobile-br {
  display: none;
  }

 /* ─── RESPONSIVE ───────────────────────────────────────── */
  @media (max-width: 1200px) {
  .cta-section {
  flex-direction: column;
  }
  
  .cta-left, .cta-right {
  padding: 60px 20px;
  }

  .cta-left-content {
  align-items: center;
  text-align: center;
  margin: 0 auto;
  }
  }

  @media (max-width: 1024px) {
  .cta-desktop-title-final { display: none !important; }
  .cta-mobile-title-final { 
  display: block !important; 
  font-size: 33px !important;
  line-height: 37px !important;
  letter-spacing: -0.89px !important;
  margin-bottom: 15px !important;
  text-align: center;
  color: #ffffff !important;
  }

  .cta-subtitle {
  width: 215px !important;
  height: 37px !important;
  margin-bottom: 20px !important;
  }

  .cta-subtitle-gold, .cta-subtitle-white {
  font-size: 13.3px !important;
  line-height: 13.3px !important;
  letter-spacing: 1.95px !important;
  color: #ffffff !important;
  }

  .cta-subtitle-gold {
  color: #EAC848 !important;
  }

  .cta-desc {
  font-size: 11.9px !important;
  line-height: 11.9px !important;
  margin-bottom: 25px !important;
  text-align: center;
  color: #ffffff !important;
  }

  .cta-contact-box {
  width: 258px !important;
  height: 33px !important;
  padding: 0 10px !important;
  margin-bottom: 15px !important;
  justify-content: center !important;
  gap: 10px !important;
  }

  .cta-contact-text {
  font-family: 'Inter', sans-serif !important;
  font-weight: 400 !important;
  font-size: 10px !important;
  line-height: 15px !important;
  color: #ffffff !important;
  }

   .cta-designer-icon {
   width: 38px !important;
   height: 38px !important;
   transform: translateY(-6px) !important;
   }

  .cta-phone-link {
  font-size: 26.25px !important;
  line-height: 35px !important;
  width: 258px !important;
  display: flex !important;
  justify-content: space-between !important;
  align-items: center !important;
  color: #ffffff !important;
  }
  
  .cta-phone-icon {
  width: 20px !important;
  height: auto !important;
  }

  .cta-form {
  max-width: 341px !important;
  margin: 0 auto !important;
  }

  .cta-submit-btn {
  font-size: 18px !important;
  line-height: 20px !important;
  height: 46px !important;
  }

  .cta-privacy-mobile-br {
  display: block;
  }
  }

 @media (max-width: 600px) {
 .form-row {
 flex-direction: column;
 gap: 25px;
 }
 }
</style>
