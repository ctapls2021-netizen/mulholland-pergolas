<style>
 .mf-section {
 width: 100%;
 display: flex;
 justify-content: center;
 background: #ffffff;
 padding: 46px 20px 0 20px;
 }

 .mf-container {
 width: 100%;
 max-width: 1421px; /* To match the banner width */
 display: flex;
 flex-direction: column;
 align-items: center;
 }

 .mf-desktop-content {
 display: flex;
 flex-direction: column;
 align-items: center;
 width: 100%;
 }

 .mf-mobile-content {
 display: none;
 }

 /* ─── TYPOGRAPHY & HEADER ───────────────────────────── */
 .mf-subtitle {
 width: 460px;
 height: 59px;
 background: #2C65B0;
 display: flex;
 align-items: center;
 justify-content: center;
 color: #ffffff;
 font-family: 'Raleway', sans-serif;
 font-weight: 800; /* Bold */
 font-size: 18px;
 line-height: 18px;
 letter-spacing: 2.64px;
 text-transform: uppercase;
 margin-bottom: 30px;
 max-width: 100%;
 }

 .mf-subtitle span {
 font-style: italic;
 color: #EAC848;
 }

 .mf-title {
 font-family: 'Raleway', sans-serif;
 font-weight: 800; /* Bold */
 font-size: 45px;
 line-height: 37px;
 letter-spacing: -0.9px;
 color: #14110E;
 text-align: center;
 margin: 0 0 25px 0;
 max-width: 100%;
 white-space: nowrap; /* No line break */
 }

 .mf-mobile-br {
  display: none;
  }

 .mf-text-blue {
 font-family: 'Raleway', sans-serif;
 font-weight: 600; /* Bold */
 font-size: 22px;
 line-height: 28px;
 color: #2C65B0;
 text-align: center;
 margin: 0 0 15px 0;
 max-width: 100%;
 white-space: nowrap; /* No line break */
 }

 .mf-text-gray {
 font-family: 'Raleway', sans-serif;
 font-weight: 400; /* Regular */
 font-size: 16px;
 line-height: 26px;
 color: #635C57;
 text-align: center;
 margin: 0 0 50px 0;
 max-width: 950px;
 }

 /* ─── ICON BOXES ────────────────────────────────────── */
 .mf-icons-grid {
 display: flex;
 justify-content: center;
 gap: 60px;
 margin-bottom: 50px;
 width: 100%;
 max-width: 1100px;
 }

 .mf-icon-item {
 display: flex;
 align-items: flex-start;
 gap: 20px;
 flex: 1;
 }

 .mf-icon {
 width: 60px;
 height: auto;
 flex-shrink: 0;
 }

 .mf-icon-text h3 {
 font-family: 'Raleway', sans-serif;
 font-weight: 800; /* Bold */
 font-size: 26px;
 line-height: 24px;
 color: #2C65B0;
 margin: 0 0 10px 0;
 white-space: nowrap; /* No line break */
 }

 .mf-icon-text p {
 font-family: 'Raleway', sans-serif;
 font-weight: 400; /* Regular */
 font-size: 14px;
 line-height: 26px;
 color: #635C57;
 margin: 0;
 }

 /* ─── GALLERY ───────────────────────────────────────── */
 .mf-gallery {
 display: grid;
 grid-template-columns: repeat(3, 1fr);
 gap: 11px; /* Set exact gap between images */
 width: 100%;
 margin-bottom: 32px;
 }

 .mf-gallery img {
 width: 100%;
 aspect-ratio: 4 / 3; /* Approximate aspect ratio based on screenshot */
 object-fit: cover;
 display: block;
 }

 /* ─── CTA BANNER ────────────────────────────────────── */
 .mf-cta-banner {
 width: 100%;
 max-width: 1421px;
 height: 105px;
 background: #2C65B0;
 display: flex;
 align-items: center;
 justify-content: center;
 box-sizing: border-box;
 }

 .mf-cta-button-container {
 display: flex;
 align-items: center;
 justify-content: center;
 width: 100%;
 }

 .mf-cta-btn {
 width: 715px;
 max-width: 90%;
 height: 56px;
 border-radius: 45px;
 background: rgba(255, 255, 255, 0.11);
 display: flex;
 align-items: center;
 justify-content: center;
 text-decoration: none;
 color: #ffffff;
 font-family: 'Inter', sans-serif;
 font-size: 19px;
 line-height: 27px;
 transition: background 0.2s;
 }

 .mf-cta-btn:hover {
 background: rgba(255, 255, 255, 0.2);
 }

 .mf-phone-icon {
 width: 20px;
 height: auto;
 margin: 0 10px;
 }

 .mf-btn-text-white {
 font-weight: 600; /* Bold */
 }

 .mf-gold {
 color: #EAC848;
 font-weight: 800; /* Bold */
 }

 .mf-mobile-btn {
 display: none !important;
 }

 /* ─── RESPONSIVE ────────────────────────────────────── */
 @media (max-width: 1200px) {
 /* Allow wrapping on smaller screens so it doesn't break layout */
 .mf-title, .mf-text-blue, .mf-icon-text h3 {
 white-space: normal;
 }
 }

  @media (max-width: 768px) {
  .mf-section {
  padding-top: 28px !important;
  }

  .mf-subtitle {
  font-size: 12.7px !important;
  line-height: 12.7px !important;
  letter-spacing: 1.87px !important;
  width: 325px !important;
  height: 35px !important;
  padding: 0 !important;
  margin-bottom: 25px !important;
  }
  .mf-title {
  font-size: 24px !important;
  line-height: 27px !important;
  letter-spacing: -0.9px !important;
  white-space: normal !important;
  padding: 0 20px;
  }
  .mf-mobile-br {
  display: block;
  }
  .mf-text-blue {
  font-size: 18px !important;
  line-height: 20px !important;
  white-space: normal !important;
  padding: 0 20px;
  }
  .mf-text-gray {
  display: none !important;
  }
  .mf-desktop-content {
  display: none !important;
  }
  .mf-mobile-content {
  display: flex;
  flex-direction: column;
  width: 100%;
  margin-bottom: 20px;
  }
  .mf-m-img {
  width: 100%;
  height: auto;
  display: block;
  margin-bottom: 42px; /* 42px gap between image and icon box */
  }
  .mf-m-feature {
  display: flex;
  align-items: flex-start;
  gap: 20px; /* Same as section 2 */
  margin-bottom: 42px;
  padding: 0 20px;
  }
  .mf-m-icon {
  width: 67px; /* Matches SVG natural width */
  height: auto;
  flex-shrink: 0;
  }
  .mf-m-feature-text {
  display: flex;
  flex-direction: column;
  }
 .mf-m-feature-text h3 {
 font-family: 'Raleway', sans-serif;
 font-weight: 800; /* Extra bold */
 font-size: 20px;
 line-height: 27px;
 color: #2C65B0;
 margin: 0 0 10px 0;
 }
  .mf-m-feature-text p {
  font-family: 'Raleway', sans-serif;
  font-weight: 400;
  font-size: 14px;
  line-height: 20px;
  color: #635C57;
  margin: 0;
  }
  .mf-desktop-btn {
  display: none !important;
  }
  .mf-mobile-btn {
  display: flex !important;
  width: 100%;
  }
  .mf-cta-banner {
  height: auto;
  padding: 0;
  border-radius: 0;
  background: transparent;
  margin-left: -20px;
  margin-right: -20px;
  width: calc(100% + 40px);
  }
  .mf-cta-button-container {
  padding: 0;
  }
  .mf-m-cta-strip {
  background: #2C65B0 !important;
  padding: 16px 10px !important;
  display: flex !important;
  justify-content: center !important;
  align-items: center !important;
  gap: 8px !important;
  text-decoration: none !important;
  width: 100% !important;
  box-sizing: border-box !important;
  height: auto !important;
  border-radius: 0 !important;
  }
  .mf-m-cta-text {
  font-family: 'Raleway', sans-serif;
  font-size: clamp(9.5px, 2.8vw, 14px);
  color: #ffffff;
  font-weight: 500;
  white-space: nowrap;
  }
  .mf-m-cta-phone {
  font-family: 'Raleway', sans-serif;
  font-size: clamp(9.5px, 2.8vw, 14px);
  color: #EAC848;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 5px;
  white-space: nowrap;
  }
  .mf-m-phone-icon {
  width: 12px;
  height: auto;
  }
  }
</style>
