---
// BlueCTAStrip.astro
---
<section class="blue-cta-strip">
  <div class="bcs-container">
    <a href="tel:8005625770" class="bcs-button">
      <span class="bcs-white-text">Request Free On-Site Estimate</span>
      <svg class="bcs-phone-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M11.527 13.807C11.6991 13.886 11.893 13.9041 12.0767 13.8582C12.2605 13.8123 12.4231 13.7052 12.5378 13.5545L12.8337 13.167C12.9889 12.96 13.1902 12.792 13.4216 12.6763C13.6531 12.5606 13.9083 12.5003 14.167 12.5003H16.667C17.109 12.5003 17.5329 12.6759 17.8455 12.9885C18.1581 13.301 18.3337 13.725 18.3337 14.167V16.667C18.3337 17.109 18.1581 17.5329 17.8455 17.8455C17.5329 18.1581 17.109 18.3337 16.667 18.3337C12.6887 18.3337 8.87344 16.7533 6.06039 13.9403C3.24734 11.1272 1.66699 7.31191 1.66699 3.33366C1.66699 2.89163 1.84259 2.46771 2.15515 2.15515C2.46771 1.84259 2.89163 1.66699 3.33366 1.66699H5.83366C6.27569 1.66699 6.69961 1.84259 7.01217 2.15515C7.32473 2.46771 7.50033 2.89163 7.50033 3.33366V5.83366C7.50033 6.0924 7.44008 6.34759 7.32437 6.57901C7.20866 6.81044 7.04065 7.01175 6.83366 7.16699L6.44366 7.45949C6.29067 7.57631 6.18284 7.74248 6.13848 7.92978C6.09413 8.11709 6.11598 8.31397 6.20033 8.48699C7.33923 10.8002 9.21235 12.671 11.527 13.807Z" stroke="#EAC848" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="bcs-yellow-text">Or Call Now: (800) 562-5770</span>
    </a>
  </div>
</section>

<style>
  .blue-cta-strip {
    width: 100%;
    background-color: #1b5391; /* Darker blue based on screenshot */
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 30px 20px;
    box-sizing: border-box;
  }

  .bcs-container {
    width: 100%;
    max-width: 1400px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .bcs-button {
    display: flex;
    align-items: center;
    gap: 12px;
    background-color: rgba(255, 255, 255, 0.15); /* Light translucent pill */
    padding: 16px 45px;
    border-radius: 50px;
    text-decoration: none;
    transition: background-color 0.3s ease;
  }

  .bcs-button:hover {
    background-color: rgba(255, 255, 255, 0.25);
  }

  .bcs-white-text {
    color: #FFF;
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-style: normal;
    font-weight: 700;
  }

  .bcs-phone-icon {
    width: 20px;
    height: auto;
    /* If the icon is not yellow natively, we can use CSS filter to make it yellow, but hopefully it is */
  }

  .bcs-yellow-text {
    color: #EAC848;
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-style: normal;
    font-weight: 700;
  }

  @media (max-width: 1200px) {
    .blue-cta-strip {
      display: none !important;
    }
  }
</style>
