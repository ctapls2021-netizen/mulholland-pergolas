---
// PergolasSection2.astro
---
<section class="pergolas-section-2">
  <div class="ps2-text-container">
    <h2 class="ps2-title">
      Advanced gate engineering<br/>& smart automation
    </h2>
    <p class="ps2-subtitle">
      Custom-designed driveway gates, whisper-quiet motors, and smart access control.
    </p>
  </div>
  <div class="ps2-image-wrapper">
    <img src="/assets/images/pergolas/section2-mobile.jpg" alt="Pergola Setup" class="ps2-image" />
  </div>
</section>

<style>
  .pergolas-section-2 {
    display: none;
  }

  @media (max-width: 1200px) {
    .pergolas-section-2 {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      background-color: #FFFFFF;
    }
  }

  .ps2-text-container {
    width: 100%;
    padding: 40px 20px 30px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-sizing: border-box;
  }

  .ps2-title {
    color: #000;
    text-align: center;
    font-family: 'Raleway', sans-serif;
    font-size: 24px;
    font-style: normal;
    font-weight: 800;
    line-height: 27px; /* 112.5% */
    letter-spacing: -0.9px;
    margin: 0 0 10px 0;
  }

  .ps2-subtitle {
    color: #000;
    text-align: center;
    font-family: 'Raleway', sans-serif;
    font-size: 14px;
    font-style: normal;
    font-weight: 500;
    line-height: 20px; /* 142.857% */
    margin: 0;
    max-width: 400px;
  }

  .ps2-image-wrapper {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .ps2-image {
    width: 100%;
    height: 314px;
    display: block;
    object-fit: cover;
  }

  .s2-image-wrapper:hover .s2-image-1, 
  .s2-image-wrapper:hover .s2-image-2 {
    transform: scale(1.05);
  }
</style>


